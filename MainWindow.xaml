<Window x:Class="DeskFlowAI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeskFlow AI"
        Width="900"
        Height="560"
        MinWidth="760"
        MinHeight="480"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F4F7FB">
        <Border Width="520"
                Padding="32"
                Background="White"
                BorderBrush="#D9E2EF"
                BorderThickness="1"
                CornerRadius="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="DeskFlow AI"
                           FontSize="34"
                           FontWeight="SemiBold"
                           Foreground="#1F2937" />

                <TextBlock Text="Kurumsal is yonetimi masaustu uygulamasi"
                           Margin="0,8,0,28"
                           FontSize="16"
                           Foreground="#526173" />

                <TextBlock x:Name="StatusTextBlock"
                           Text="Uygulama acildi. Henuz login eklemedik."
                           Margin="0,0,0,18"
                           FontSize="15"
                           Foreground="#334155" />

                <Button Content="C# kodunu calistir"
                        Width="180"
                        Height="40"
                        HorizontalAlignment="Left"
                        Click="RunCodeButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>

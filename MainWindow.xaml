<Window x:Class="DeskFlowAI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:DeskFlowAI.Converters"
        Title="DeskFlow AI"
        Width="1160"
        Height="720"
        MinWidth="900"
        MinHeight="640"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:StatusBadgeConverter x:Key="StatusBadgeConverter" />

        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F7F9FC" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#E5EAF2" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A" />
        <SolidColorBrush x:Key="WarningBrush" Color="#D97706" />
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#111827" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="#D7DEE8" />

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="13,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1E40AF" />
                                <Setter TargetName="ButtonBorder" Property="Margin" Value="0,1,0,-1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F8FAFC" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#B8C4D4" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E2E8F0" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#94A3B8" />
                                <Setter TargetName="ButtonBorder" Property="Margin" Value="0,1,0,-1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="#FEF2F2" />
            <Setter Property="BorderBrush" Value="#FECACA" />
            <Setter Property="Foreground" Value="#991B1B" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F8FAFC" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF6FF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE" />
                    <Setter Property="Foreground" Value="#0F172A" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OverdueTaskRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                    <Setter Property="Background" Value="#FEF2F2" />
                    <Setter Property="Foreground" Value="#991B1B" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EmployeeWorkloadRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding NeedsCoverage}" Value="True">
                    <Setter Property="Background" Value="#FFFBEB" />
                    <Setter Property="Foreground" Value="#92400E" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="HelperTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="LineHeight" Value="18" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>

        <Style x:Key="FormGroupStyle" TargetType="Border">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="FormGroupTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowHeight" Value="38" />
            <Setter Property="ColumnHeaderHeight" Value="40" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="AlternationCount" Value="2" />
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF2F7" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="BorderBrush" Value="#E5EAF2" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="BadgeBorderStyle" TargetType="Border">
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="WorkflowStepStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
        </Style>

        <Style x:Key="WorkflowArrowStyle" TargetType="TextBlock">
            <Setter Property="Text" Value=">" />
            <Setter Property="Margin" Value="6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#94A3B8" />
        </Style>

        <Style x:Key="WorkflowStepTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="ModernScrollBarButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Margin="1.5"
                                Background="#94A3B8"
                                CornerRadius="6" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#64748B" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#475569" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="#E2E8F0"
                                CornerRadius="7">
                            <Track x:Name="PART_Track"
                                   Orientation="{TemplateBinding Orientation}"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ModernScrollBarButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModernScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ModernScrollBarButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="#EEF3F8"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="9,9,0,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="White" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#2563EB" />
                                <Setter Property="Foreground" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid x:Name="LoginView">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#17324D"
                    Padding="56">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="DeskFlow AI"
                               FontSize="42"
                               FontWeight="SemiBold"
                               Foreground="White" />

                    <TextBlock Text="Manage customers, projects, tasks, documents, and AI review in one workspace."
                               Margin="0,18,0,0"
                               FontSize="18"
                               LineHeight="28"
                               TextWrapping="Wrap"
                               Foreground="#D9E6F2" />

                    <Border Margin="0,42,0,0"
                            Padding="18"
                            Background="#24445F"
                            BorderBrush="#3F6380"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Demo accounts"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="White" />

                            <TextBlock Text="admin, manager veya staff @deskflow.ai / Admin123"
                                       Margin="0,8,0,0"
                                       FontSize="14"
                                       Foreground="#CFE0EF" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <Border MaxWidth="420"
                        Margin="56"
                        Padding="34"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Sign in"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937" />

                        <TextBlock Text="Sign in to the internal operations workspace."
                                   Margin="0,8,0,28"
                                   FontSize="15"
                                   Foreground="#64748B" />

                        <TextBlock Text="Email" Style="{StaticResource FieldLabelStyle}" />

                        <TextBox x:Name="EmailTextBox"
                                 Style="{StaticResource InputStyle}"
                                 Text="admin@deskflow.ai" />

                        <TextBlock Text="Password"
                                   Margin="0,18,0,6"
                                   Style="{StaticResource FieldLabelStyle}" />

                        <PasswordBox x:Name="PasswordBox"
                                     Height="42"
                                     Padding="12,0"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="#CBD5E1"
                                     BorderThickness="1"
                                     Password="Admin123"
                                     KeyDown="PasswordBox_KeyDown" />

                        <TextBlock x:Name="LoginErrorTextBlock"
                                   Margin="0,14,0,0"
                                   FontSize="13"
                                   Foreground="#DC2626"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed" />

                        <Button Content="Sign in"
                                Height="42"
                                Margin="0,24,0,0"
                                Background="#2563EB"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Click="SignInButton_Click" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="DashboardView" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="#1E40AF"
                    BorderThickness="0,0,0,1"
                    Padding="22,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0F172A" Offset="0" />
                        <GradientStop Color="#1D4ED8" Offset="0.62" />
                        <GradientStop Color="#0F766E" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="DeskFlow AI"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="White" />

                        <TextBlock x:Name="SignedInUserTextBlock"
                                   Margin="14,3,0,0"
                                   FontSize="13"
                                   Foreground="#DBEAFE" />
                    </StackPanel>

                    <Button DockPanel.Dock="Right"
                            Content="Sign out"
                            Width="90"
                            Height="32"
                            Margin="0,12,0,12"
                            Background="#EFF6FF"
                            BorderBrush="#93C5FD"
                            Foreground="#0F172A"
                            Click="SignOutButton_Click" />
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.45*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}" Background="#ECFDF5" BorderBrush="#BBF7D0">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Text="Open tasks"
                                               Foreground="#166534"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="OpenTasksTextBlock"
                                               DockPanel.Dock="Right"
                                               Text="0"
                                               FontSize="36"
                                               FontWeight="SemiBold"
                                               Foreground="#15803D"
                                               HorizontalAlignment="Right" />
                                </DockPanel>

                                <TextBlock Text="Work currently waiting on the team"
                                           Margin="0,4,0,10"
                                           FontSize="12"
                                           Foreground="#64748B" />

                                <Border Height="6" Background="#DCFCE7" CornerRadius="3">
                                    <Border Width="180"
                                            HorizontalAlignment="Left"
                                            Background="#22C55E"
                                            CornerRadius="3" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}" Background="#EFF6FF">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Text="Active projects" Foreground="#1E3A8A" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <TextBlock x:Name="ActiveProjectsTextBlock" DockPanel.Dock="Right" Text="0" FontSize="26" FontWeight="SemiBold" Foreground="#1D4ED8" HorizontalAlignment="Right" />
                                </DockPanel>

                                <TextBlock Text="In delivery or planning"
                                           Margin="0,7,0,0"
                                           FontSize="12"
                                           Foreground="#64748B" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Style="{StaticResource MetricCardStyle}" Background="#FEF2F2" BorderBrush="#FECACA">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Text="Overdue work" Foreground="#991B1B" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <TextBlock x:Name="OverdueTasksTextBlock" DockPanel.Dock="Right" Text="0" FontSize="26" FontWeight="SemiBold" Foreground="#B91C1C" HorizontalAlignment="Right" />
                                </DockPanel>

                                <TextBlock Text="Needs attention"
                                           Margin="0,7,0,8"
                                           FontSize="12"
                                           Foreground="#64748B" />

                                <Border Height="5" Background="#FEE2E2" CornerRadius="3">
                                    <Border Width="90"
                                            HorizontalAlignment="Left"
                                            Background="#EF4444"
                                            CornerRadius="3" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="6" Style="{StaticResource MetricCardStyle}" Background="#FFFBEB" BorderBrush="#FDE68A">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Text="AI queue" Foreground="#92400E" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <TextBlock x:Name="PendingAiDocumentsTextBlock" DockPanel.Dock="Right" Text="0" FontSize="26" FontWeight="SemiBold" Foreground="#B45309" HorizontalAlignment="Right" />
                                </DockPanel>

                                <TextBlock Text="Review queue"
                                           Margin="0,7,0,8"
                                           FontSize="12"
                                           Foreground="#64748B" />

                                <Border Height="5" Background="#FEF3C7" CornerRadius="3">
                                    <Border Width="110"
                                            HorizontalAlignment="Left"
                                            Background="#F59E0B"
                                            CornerRadius="3" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                <Border Grid.Row="1"
                        Margin="0,14,0,0"
                        Padding="12"
                        Background="White"
                        BorderBrush="#D8E1EC"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="AI policy"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="#334155" />

                        <UniformGrid Grid.Column="1"
                                     Columns="4"
                                     Margin="18,0,0,0">
                            <TextBlock x:Name="InternalOnlyDocumentsTextBlock"
                                       Text="Internal Only: 0"
                                       Foreground="#334155"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="ExternalAIAllowedDocumentsTextBlock"
                                       Text="External AI Allowed: 0"
                                       Foreground="#166534"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="NeedsApprovalDocumentsTextBlock"
                                       Text="Needs Approval: 0"
                                       Foreground="#92400E"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="BlockedDocumentsTextBlock"
                                       Text="Blocked: 0"
                                       Foreground="#991B1B"
                                       FontWeight="SemiBold" />
                        </UniformGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,10,0,0"
                        Padding="12"
                        Background="#F8FAFC"
                        BorderBrush="#D8E1EC"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Notifications"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="#334155" />

                        <Border Grid.Column="1"
                                Margin="8,0,0,0"
                                Padding="8,3"
                                Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="9"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="UnreadNotificationsTextBlock"
                                       Text="0 unread"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#1D4ED8" />
                        </Border>

                        <Grid Grid.Column="2" Margin="18,0,0,0">
                            <ItemsControl x:Name="DashboardNotificationsItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,8,0"
                                                Padding="9,5"
                                                Background="{Binding Severity, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Background}"
                                                BorderBrush="{Binding Severity, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Border}"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding Severity, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Foreground}" />
                                                <TextBlock Text="{Binding Message}"
                                                           Margin="8,0,0,0"
                                                           FontSize="12"
                                                           Foreground="#334155" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock x:Name="NotificationsEmptyTextBlock"
                                       Text="No active notifications."
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#64748B"
                                       VerticalAlignment="Center"
                                       Visibility="Visible" />
                        </Grid>

                        <Button x:Name="MarkNotificationsReadButton"
                                Grid.Column="3"
                                Content="Mark all read"
                                Height="30"
                                Margin="12,0,0,0"
                                Padding="12,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="MarkNotificationsReadButton_Click" />
                    </Grid>
                </Border>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="LeftWorkspaceColumn" Width="1.15*" MinWidth="360" />
                        <ColumnDefinition x:Name="MainSplitterColumn" Width="10" />
                        <ColumnDefinition x:Name="RightWorkspaceColumn" Width="1*" MinWidth="420" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="CustomerWorkspaceBorder"
                            Grid.Column="0"
                            Padding="20"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="1*" MinHeight="120" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="1.2*" MinHeight="160" />
                            </Grid.RowDefinitions>

                            <Border Margin="0,0,0,8"
                                    Padding="12"
                                    Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Customers"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="#0F172A" />

                                        <TextBlock Text="Customer records, contacts, and account status."
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Foreground="#64748B" />
                                    </StackPanel>

                                    <Button x:Name="DeleteCustomerButton"
                                            Grid.Column="2"
                                            Content="Delete selected"
                                            Width="138"
                                            Height="38"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Click="DeleteCustomerButton_Click" />
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1"
                                  Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="112" />
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="CustomerSearchTextBox"
                                         Height="34"
                                         Padding="12,0"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         BorderBrush="#CBD5E1"
                                         BorderThickness="1"
                                         TextChanged="CustomerSearchTextBox_TextChanged" />

                                <Button Grid.Column="2"
                                        Content="Clear"
                                        Height="34"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="ClearCustomerSearchButton_Click" />
                            </Grid>

                            <DataGrid x:Name="CustomersDataGrid"
                                      Grid.Row="2"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionChanged="CustomersDataGrid_SelectionChanged"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      BorderBrush="#E2E8F0"
                                      BorderThickness="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Company" Binding="{Binding CompanyName}" Width="180" />
                                    <DataGridTextColumn Header="Contact" Binding="{Binding ContactName}" Width="150" />
                                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="240" />
                                    <DataGridTemplateColumn Header="Status" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource BadgeBorderStyle}"
                                                        Background="{Binding Status, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Background}"
                                                        BorderBrush="{Binding Status, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Border}">
                                                    <TextBlock Text="{Binding Status, Converter={StaticResource StatusBadgeConverter}}"
                                                               Foreground="{Binding Status, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Foreground}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <GridSplitter Grid.Row="3"
                                          Height="8"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center"
                                          ResizeDirection="Rows"
                                          ResizeBehavior="PreviousAndNext"
                                          Background="Transparent"
                                          ShowsPreview="True">
                                <GridSplitter.Template>
                                    <ControlTemplate TargetType="GridSplitter">
                                        <Grid Background="Transparent">
                                            <Border Height="2"
                                                    Width="72"
                                                    Background="#CBD5E1"
                                                    CornerRadius="1"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                        </Grid>
                                    </ControlTemplate>
                                </GridSplitter.Template>
                            </GridSplitter>

                            <TextBlock Grid.Row="4"
                                       Text="Audit log"
                                       Margin="0,8,0,8"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#1F2937" />

                            <DataGrid x:Name="AuditLogsDataGrid"
                                      Grid.Row="5"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      BorderBrush="#E2E8F0"
                                      BorderThickness="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding OccurredAt, StringFormat={}{0:HH:mm:ss}}" Width="90" />
                                    <DataGridTextColumn Header="Actor" Binding="{Binding ActorEmail}" Width="180" />
                                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="110" />
                                    <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="360" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <GridSplitter x:Name="MainWorkspaceGridSplitter"
                                  Grid.Column="1"
                                  Width="10"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeBehavior="PreviousAndNext"
                                  Background="Transparent"
                                  ShowsPreview="True">
                        <GridSplitter.Template>
                            <ControlTemplate TargetType="GridSplitter">
                                <Border Background="#D8E1EC"
                                        Width="2"
                                        CornerRadius="1"
                                        HorizontalAlignment="Center"
                                        Margin="0,8" />
                            </ControlTemplate>
                        </GridSplitter.Template>
                    </GridSplitter>

                    <Border Grid.Column="2"
                            Padding="16"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <TabControl x:Name="WorkspaceTabControl">
                            <TabItem x:Name="CustomerTab" Header="Customers">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="0,12,0,0">
                                <Border Style="{StaticResource SectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock x:Name="CustomerFormTitleTextBlock"
                                                   Text="Add customer"
                                                   Style="{StaticResource SectionTitleStyle}" />

                                        <TextBlock Text="Create a customer record or update the selected customer."
                                                   Style="{StaticResource HelperTextStyle}" />

                                        <Border Style="{StaticResource FormGroupStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Company profile"
                                                           Style="{StaticResource FormGroupTitleStyle}" />

                                                <TextBlock Text="Company"
                                                           Margin="0,14,0,6"
                                                           Style="{StaticResource FieldLabelStyle}" />

                                                <TextBox x:Name="CustomerCompanyTextBox"
                                                         Style="{StaticResource InputStyle}" />

                                                <TextBlock Text="Use the legal or customer-facing company name."
                                                           Style="{StaticResource HelperTextStyle}" />

                                                <TextBlock Text="Contact"
                                                           Margin="0,14,0,6"
                                                           Style="{StaticResource FieldLabelStyle}" />

                                                <TextBox x:Name="CustomerContactTextBox"
                                                         Style="{StaticResource InputStyle}" />

                                                <TextBlock Text="Primary person for project updates."
                                                           Style="{StaticResource HelperTextStyle}" />
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource FormGroupStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Communication"
                                                           Style="{StaticResource FormGroupTitleStyle}" />

                                                <TextBlock Text="Email"
                                                           Margin="0,14,0,6"
                                                           Style="{StaticResource FieldLabelStyle}" />

                                                <TextBox x:Name="CustomerEmailTextBox"
                                                         Style="{StaticResource InputStyle}" />

                                                <TextBlock Text="Must be unique; this is used to identify the customer."
                                                           Style="{StaticResource HelperTextStyle}" />
                                            </StackPanel>
                                        </Border>

                                        <TextBlock x:Name="CustomerFormMessageTextBlock"
                                                   Margin="0,12,0,0"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   Visibility="Collapsed" />

                                        <Button x:Name="AddCustomerButton"
                                                Content="Add customer"
                                                Margin="0,18,0,0"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Click="AddCustomerButton_Click" />

                                        <UniformGrid Columns="2"
                                                     Margin="0,10,0,0">
                                            <Button x:Name="UpdateCustomerButton"
                                                    Content="Update"
                                                    Margin="0,0,5,0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Click="UpdateCustomerButton_Click" />

                                            <Button Content="Clear"
                                                    Margin="5,0,0,0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Click="ClearCustomerFormButton_Click" />
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem x:Name="ProjectsTab" Header="Projects">
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.3*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="0.9*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto">
                                        <Grid MinWidth="680">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Project list" Style="{StaticResource SectionTitleStyle}" />

                                                <TextBlock Text="Shows all projects or the selected customer's projects by due date."
                                                           Margin="0,4,0,0"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Foreground="#64748B" />

                                                <TextBlock x:Name="SelectedCustomerForProjectTextBlock"
                                                           Text="Select a customer from the list first."
                                                           Margin="0,10,0,0"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Foreground="#334155" />
                                            </StackPanel>

                                            <DataGrid x:Name="ProjectsDataGrid"
                                                      Grid.Row="1"
                                                      MinHeight="260"
                                                      Margin="0,16,0,0"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      SelectionMode="Single"
                                                      SelectionChanged="ProjectsDataGrid_SelectionChanged"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                      BorderBrush="#E2E8F0"
                                                      BorderThickness="1">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Project" Binding="{Binding Name}" Width="220" />
                                                    <DataGridTextColumn Header="Customer" Binding="{Binding Customer.CompanyName}" Width="180" />
                                                    <DataGridTemplateColumn Header="Status" Width="130">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource BadgeBorderStyle}"
                                                                        Background="{Binding Status, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Background}"
                                                                        BorderBrush="{Binding Status, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Border}">
                                                                    <TextBlock Text="{Binding Status, Converter={StaticResource StatusBadgeConverter}}"
                                                                               Foreground="{Binding Status, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Foreground}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="Due" Binding="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy}}" Width="110" />
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <TextBlock x:Name="ProjectsEmptyTextBlock"
                                                       Grid.Row="2"
                                                       Text="No projects for this customer yet."
                                                       Margin="0,10,0,0"
                                                       FontSize="13"
                                                       Foreground="#64748B"
                                                       Visibility="Collapsed" />
                                        </Grid>
                                        </ScrollViewer>
                                    </Border>

                                    <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Auto">
                                        <StackPanel MinWidth="380">
                                            <DockPanel LastChildFill="True">
                                                <Button x:Name="ExportProjectReportButton"
                                                        DockPanel.Dock="Right"
                                                        Content="Export PDF"
                                                        Width="110"
                                                        Height="32"
                                                        Margin="10,0,0,0"
                                                        Padding="8,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        IsEnabled="False"
                                                        Click="ExportProjectReportButton_Click" />
                                                <TextBlock Text="Project details" Style="{StaticResource SectionTitleStyle}" />
                                            </DockPanel>

                                            <TextBlock Text="Add a project or update the selected project's status."
                                                       Margin="0,4,0,10"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"
                                                       Foreground="#64748B" />

                                            <Border Style="{StaticResource FormGroupStyle}" Margin="0,0,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Project identity"
                                                               Style="{StaticResource FormGroupTitleStyle}" />

                                                    <TextBlock Text="Project name"
                                                               Margin="0,14,0,6"
                                                               Style="{StaticResource FieldLabelStyle}" />

                                                    <TextBox x:Name="ProjectNameTextBox"
                                                             Height="36"
                                                             Style="{StaticResource InputStyle}" />

                                                    <TextBlock Text="Use a short name that the team can recognize in lists."
                                                               Style="{StaticResource HelperTextStyle}" />

                                                    <TextBlock Text="Workflow"
                                                               Margin="0,16,0,0"
                                                               Style="{StaticResource FormGroupTitleStyle}" />

                                                    <TextBlock Text="Status"
                                                               Margin="0,10,0,6"
                                                               Style="{StaticResource FieldLabelStyle}" />

                                                    <ComboBox x:Name="ProjectStatusComboBox"
                                                              Height="36"
                                                              SelectedIndex="0">
                                                        <ComboBoxItem Content="Planning" />
                                                        <ComboBoxItem Content="Active" />
                                                        <ComboBoxItem Content="On Hold" />
                                                        <ComboBoxItem Content="Completed" />
                                                    </ComboBox>

                                                    <TextBlock Text="Status drives dashboards and project overview lists."
                                                               Style="{StaticResource HelperTextStyle}" />

                                                    <TextBlock Text="Due date"
                                                               Margin="0,10,0,6"
                                                               Style="{StaticResource FieldLabelStyle}" />

                                                    <DatePicker x:Name="ProjectDueDatePicker"
                                                                Height="36" />

                                                    <TextBlock Text="Optional, but recommended for due-soon tracking."
                                                               Style="{StaticResource HelperTextStyle}" />
                                                </StackPanel>
                                            </Border>

                                            <UniformGrid Columns="2" Margin="0,12,0,0">
                                                        <Button x:Name="AddProjectButton"
                                                                Content="Add project"
                                                                Margin="0,0,5,0"
                                                        Height="34"
                                                        Padding="10,0"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Click="AddProjectButton_Click" />

                                                        <Button x:Name="UpdateProjectStatusButton"
                                                                Content="Update status"
                                                                Margin="5,0,0,0"
                                                        Height="34"
                                                        Padding="10,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        IsEnabled="False"
                                                        Click="UpdateProjectStatusButton_Click" />
                                            </UniformGrid>

                                            <Border Style="{StaticResource FormGroupStyle}" Margin="0,12,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Project team"
                                                               Style="{StaticResource FormGroupTitleStyle}" />

                                                    <TextBlock Text="Team members working on this project based on task assignments."
                                                               Style="{StaticResource HelperTextStyle}" />

                                                    <ItemsControl x:Name="ProjectTeamItemsControl"
                                                                  Margin="0,12,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Margin="0,0,0,8"
                                                                        Padding="10"
                                                                        Background="White"
                                                                        BorderBrush="#E2E8F0"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding FullName}"
                                                                                       FontSize="13"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="#0F172A" />

                                                                            <TextBlock Text="{Binding RoleText}"
                                                                                       Margin="0,3,0,0"
                                                                                       FontSize="12"
                                                                                       Foreground="#64748B" />

                                                                            <TextBlock Text="{Binding Email}"
                                                                                       Margin="0,3,0,0"
                                                                                       FontSize="11"
                                                                                       Foreground="#64748B" />
                                                                        </StackPanel>

                                                                        <StackPanel Grid.Column="1"
                                                                                    Margin="10,0,0,0"
                                                                                    HorizontalAlignment="Right">
                                                                            <Border Style="{StaticResource BadgeBorderStyle}"
                                                                                    HorizontalAlignment="Right"
                                                                                    Background="{Binding AvailabilityStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Background}"
                                                                                    BorderBrush="{Binding AvailabilityStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Border}">
                                                                                <TextBlock Text="{Binding AvailabilityStatus, Converter={StaticResource StatusBadgeConverter}}"
                                                                                           Foreground="{Binding AvailabilityStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Foreground}"
                                                                                           FontSize="11"
                                                                                           FontWeight="SemiBold" />
                                                                            </Border>

                                                                            <TextBlock Text="{Binding WorkloadText}"
                                                                                       Margin="0,6,0,0"
                                                                                       FontSize="11"
                                                                                       FontWeight="SemiBold"
                                                                                       TextAlignment="Right"
                                                                                       Foreground="#334155" />
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <TextBlock x:Name="ProjectTeamEmptyTextBlock"
                                                               Text="No assigned team members for this project yet."
                                                               Margin="0,10,0,0"
                                                               FontSize="12"
                                                               Foreground="#64748B"
                                                               Visibility="Visible" />
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource FormGroupStyle}" Margin="0,12,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Team note"
                                                               Style="{StaticResource FormGroupTitleStyle}" />

                                                    <TextBlock Text="Sent as a notification to the selected project team."
                                                               Style="{StaticResource HelperTextStyle}" />

                                                    <TextBox x:Name="ProjectNoteTextBox"
                                                             Height="56"
                                                             Margin="0,8,0,0"
                                                             Padding="10,8"
                                                             TextWrapping="Wrap"
                                                             AcceptsReturn="True"
                                                             BorderBrush="#CBD5E1"
                                                             BorderThickness="1" />

                                                    <Button x:Name="SendProjectNoteButton"
                                                            Content="Send note to team"
                                                            Margin="0,10,0,0"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Click="SendProjectNoteButton_Click" />
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource FormGroupStyle}" Margin="0,12,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Activity timeline"
                                                               Style="{StaticResource FormGroupTitleStyle}" />

                                                    <TextBlock Text="Task, document, and AI activity for the selected project."
                                                               Style="{StaticResource HelperTextStyle}" />

                                                    <ItemsControl x:Name="ProjectTimelineItemsControl"
                                                                  Margin="0,12,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,12">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="18" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>

                                                                    <Grid Grid.Column="0">
                                                                        <Border Width="2"
                                                                                Margin="8,12,0,-18"
                                                                                HorizontalAlignment="Left"
                                                                                Background="#E2E8F0" />
                                                                        <Ellipse Width="10"
                                                                                 Height="10"
                                                                                 Margin="4,8,0,0"
                                                                                 HorizontalAlignment="Left"
                                                                                 VerticalAlignment="Top"
                                                                                 Fill="#2563EB" />
                                                                    </Grid>

                                                                    <Border Grid.Column="1"
                                                                            Background="White"
                                                                            BorderBrush="#E2E8F0"
                                                                            BorderThickness="1"
                                                                            CornerRadius="8"
                                                                            Padding="10">
                                                                        <StackPanel>
                                                                            <DockPanel LastChildFill="True">
                                                                                <TextBlock Text="{Binding TimeText}"
                                                                                           DockPanel.Dock="Right"
                                                                                           Margin="10,0,0,0"
                                                                                           FontSize="11"
                                                                                           Foreground="#94A3B8" />
                                                                                <StackPanel Orientation="Horizontal">
                                                                                    <Border Style="{StaticResource BadgeBorderStyle}"
                                                                                            Background="{Binding Action, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Background}"
                                                                                            BorderBrush="{Binding Action, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Border}">
                                                                                        <TextBlock Text="{Binding Action}"
                                                                                                   Foreground="{Binding Action, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Foreground}"
                                                                                                   FontSize="11"
                                                                                                   FontWeight="SemiBold" />
                                                                                    </Border>

                                                                                    <TextBlock Text="{Binding EntityName}"
                                                                                               Margin="8,2,0,0"
                                                                                               FontSize="12"
                                                                                               FontWeight="SemiBold"
                                                                                               Foreground="#334155" />
                                                                                </StackPanel>
                                                                            </DockPanel>

                                                                            <TextBlock Text="{Binding Details}"
                                                                                       Margin="0,8,0,0"
                                                                                       FontSize="12"
                                                                                       TextWrapping="Wrap"
                                                                                       Foreground="#475569" />

                                                                            <TextBlock Text="{Binding ActorEmail}"
                                                                                       Margin="0,6,0,0"
                                                                                       FontSize="11"
                                                                                       Foreground="#64748B" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <TextBlock x:Name="ProjectTimelineEmptyTextBlock"
                                                               Text="No timeline activity for this project yet."
                                                               Margin="0,10,0,0"
                                                               FontSize="12"
                                                               Foreground="#64748B"
                                                               Visibility="Visible" />
                                                </StackPanel>
                                            </Border>

                                            <TextBlock x:Name="ProjectFormMessageTextBlock"
                                                       Margin="0,12,0,0"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"
                                                       Visibility="Collapsed" />
                                        </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem x:Name="TasksTab" Header="Tasks">
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.25*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="0.95*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto">
                                        <Grid MinWidth="760">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel>
                                                <TextBlock x:Name="TaskListTitleTextBlock"
                                                           Text="Task list"
                                                           Style="{StaticResource SectionTitleStyle}" />

                                                <TextBlock x:Name="TaskListDescriptionTextBlock"
                                                           Text="Tasks in the selected project are sorted by due date and priority."
                                                           Margin="0,4,0,0"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Foreground="#64748B" />

                                                <TextBlock x:Name="SelectedProjectForTaskTextBlock"
                                                           Text="Select a project from the Projects tab first."
                                                           Margin="0,10,0,0"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Foreground="#334155" />

                                                <Grid Margin="0,14,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="10" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="10" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Status filter" Style="{StaticResource FieldLabelStyle}" />
                                                        <ComboBox x:Name="TaskStatusFilterComboBox"
                                                                  Height="36"
                                                                  SelectedIndex="0"
                                                                  SelectionChanged="TaskFilter_Changed">
                                                            <ComboBoxItem Content="All statuses" />
                                                            <ComboBoxItem Content="To Do" />
                                                            <ComboBoxItem Content="In Progress" />
                                                            <ComboBoxItem Content="Review" />
                                                            <ComboBoxItem Content="Blocked" />
                                                            <ComboBoxItem Content="Done" />
                                                        </ComboBox>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Priority filter" Style="{StaticResource FieldLabelStyle}" />
                                                        <ComboBox x:Name="TaskPriorityFilterComboBox"
                                                                  Height="36"
                                                                  SelectedIndex="0"
                                                                  SelectionChanged="TaskFilter_Changed">
                                                            <ComboBoxItem Content="All priorities" />
                                                            <ComboBoxItem Content="Low" />
                                                            <ComboBoxItem Content="Normal" />
                                                            <ComboBoxItem Content="High" />
                                                            <ComboBoxItem Content="Critical" />
                                                        </ComboBox>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="Due filter" Style="{StaticResource FieldLabelStyle}" />
                                                        <ComboBox x:Name="TaskDueDateFilterComboBox"
                                                                  Height="36"
                                                                  SelectedIndex="0"
                                                                  SelectionChanged="TaskFilter_Changed">
                                                            <ComboBoxItem Content="All dates" />
                                                            <ComboBoxItem Content="Overdue" />
                                                            <ComboBoxItem Content="Due today" />
                                                            <ComboBoxItem Content="Due in 7 days" />
                                                            <ComboBoxItem Content="No due date" />
                                                        </ComboBox>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>

                                            <DataGrid x:Name="TasksDataGrid"
                                                      Grid.Row="1"
                                                      MinHeight="260"
                                                      Margin="0,16,0,0"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      SelectionMode="Single"
                                                      SelectionChanged="TasksDataGrid_SelectionChanged"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                      BorderBrush="#E2E8F0"
                                                      BorderThickness="1"
                                                      RowStyle="{StaticResource OverdueTaskRowStyle}">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Task" Binding="{Binding Title}" Width="190" />
                                                    <DataGridTextColumn Header="Assigned To" Binding="{Binding AssignedEmployee.FullName}" Width="140" />
                                                    <DataGridTemplateColumn Header="Status" Width="120">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource BadgeBorderStyle}"
                                                                        Background="{Binding Status, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Background}"
                                                                        BorderBrush="{Binding Status, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Border}">
                                                                    <TextBlock Text="{Binding Status, Converter={StaticResource StatusBadgeConverter}}"
                                                                               Foreground="{Binding Status, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Foreground}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Priority" Width="110">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource BadgeBorderStyle}"
                                                                        Background="{Binding Priority, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Background}"
                                                                        BorderBrush="{Binding Priority, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Border}">
                                                                    <TextBlock Text="{Binding Priority, Converter={StaticResource StatusBadgeConverter}}"
                                                                               Foreground="{Binding Priority, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Foreground}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="Blocked by" Binding="{Binding BlockedBy}" Width="150" />
                                                    <DataGridTextColumn Header="Due" Binding="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy}}" Width="110" />
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <TextBlock x:Name="TasksEmptyTextBlock"
                                                       Grid.Row="2"
                                                       Text="No tasks for this project yet."
                                                       Margin="0,10,0,0"
                                                       FontSize="13"
                                                       Foreground="#64748B"
                                                       Visibility="Collapsed" />
                                        </Grid>
                                        </Grid>
                                        </ScrollViewer>
                                    </Border>

                                    <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Auto">
                                        <StackPanel MinWidth="360">
                                            <TextBlock x:Name="TaskDetailsTitleTextBlock"
                                                       Text="Task details"
                                                       Style="{StaticResource SectionTitleStyle}" />

                                            <TextBlock x:Name="TaskDetailsDescriptionTextBlock"
                                                       Text="Add a task or update the selected task workflow."
                                                       Margin="0,4,0,16"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"
                                                       Foreground="#64748B" />

                                            <Border Style="{StaticResource FormGroupStyle}" Margin="0,0,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Task identity"
                                                               Style="{StaticResource FormGroupTitleStyle}" />

                                                    <TextBlock Text="Task title"
                                                               Margin="0,14,0,6"
                                                               Style="{StaticResource FieldLabelStyle}" />

                                                    <TextBox x:Name="TaskTitleTextBox"
                                                             Style="{StaticResource InputStyle}" />

                                                    <TextBlock Text="Keep it action-oriented so the assignee knows what to do."
                                                               Style="{StaticResource HelperTextStyle}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource FormGroupStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Workflow"
                                                               Style="{StaticResource FormGroupTitleStyle}" />

                                                    <TextBlock Text="Status"
                                                               Margin="0,14,0,6"
                                                               Style="{StaticResource FieldLabelStyle}" />

                                                    <ComboBox x:Name="TaskStatusComboBox"
                                                              Height="40"
                                                              SelectedIndex="0">
                                                        <ComboBoxItem Content="To Do" />
                                                        <ComboBoxItem Content="In Progress" />
                                                        <ComboBoxItem Content="Review" />
                                                        <ComboBoxItem Content="Blocked" />
                                                        <ComboBoxItem Content="Done" />
                                                    </ComboBox>

                                                    <TextBlock Text="Use Blocked when progress needs a manager or customer decision."
                                                               Style="{StaticResource HelperTextStyle}" />

                                                    <TextBlock Text="Priority"
                                                               Margin="0,14,0,6"
                                                               Style="{StaticResource FieldLabelStyle}" />

                                                    <ComboBox x:Name="TaskPriorityComboBox"
                                                              Height="40"
                                                              SelectedIndex="1">
                                                        <ComboBoxItem Content="Low" />
                                                        <ComboBoxItem Content="Normal" />
                                                        <ComboBoxItem Content="High" />
                                                        <ComboBoxItem Content="Critical" />
                                                    </ComboBox>

                                                    <TextBlock Text="High and Critical tasks stand out in lists and dashboards."
                                                               Style="{StaticResource HelperTextStyle}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource FormGroupStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Ownership"
                                                               Style="{StaticResource FormGroupTitleStyle}" />

                                                    <TextBlock Text="Assigned to"
                                                               Margin="0,14,0,6"
                                                               Style="{StaticResource FieldLabelStyle}" />

                                                    <ComboBox x:Name="TaskAssignedEmployeeComboBox"
                                                              Height="40"
                                                              DisplayMemberPath="FullName"
                                                              SelectedValuePath="Id" />

                                                    <TextBlock Text="Optional, but required for staff-specific task views."
                                                               Style="{StaticResource HelperTextStyle}" />

                                                    <TextBlock Text="Due date"
                                                               Margin="0,14,0,6"
                                                               Style="{StaticResource FieldLabelStyle}" />

                                                    <DatePicker x:Name="TaskDueDatePicker"
                                                                Height="40" />

                                                    <TextBlock Text="Used for overdue and due-soon filtering."
                                                               Style="{StaticResource HelperTextStyle}" />

                                                    <TextBlock Text="Blocked by / dependency"
                                                               Margin="0,14,0,6"
                                                               Style="{StaticResource FieldLabelStyle}" />

                                                    <TextBox x:Name="TaskBlockedByTextBox"
                                                             Style="{StaticResource InputStyle}" />

                                                    <TextBlock Text="Example: customer approval, API access, contract signoff."
                                                               Style="{StaticResource HelperTextStyle}" />
                                                </StackPanel>
                                            </Border>

                                            <Button x:Name="AddTaskButton"
                                                    Content="Add task"
                                                    Margin="0,18,0,0"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Click="AddTaskButton_Click" />

                                            <Button x:Name="UpdateTaskButton"
                                                    Content="Update task"
                                                    Margin="0,10,0,0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    IsEnabled="False"
                                                    Click="UpdateTaskButton_Click" />

                                            <Button x:Name="MarkTaskDoneButton"
                                                    Content="Mark as done"
                                                    Margin="0,10,0,0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    IsEnabled="False"
                                                    Click="MarkTaskDoneButton_Click" />

                                            <TextBlock x:Name="TaskFormMessageTextBlock"
                                                       Margin="0,12,0,0"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"
                                                       Visibility="Collapsed" />
                                        </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem x:Name="BoardTab" Header="Board">
                                <Border Style="{StaticResource SectionCardStyle}" Margin="0,12,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Kanban board"
                                                       Style="{StaticResource SectionTitleStyle}" />

                                            <TextBlock x:Name="SelectedProjectForBoardTextBlock"
                                                       Text="Select a project from the Projects tab first."
                                                       Margin="0,4,0,0"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       Foreground="#475569" />
                                        </StackPanel>

                                        <ScrollViewer Grid.Row="1"
                                                      Margin="0,16,0,0"
                                                      HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Disabled">
                                            <Grid MinWidth="1160">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Tag="To Do"
                                                        AllowDrop="True"
                                                        Drop="KanbanColumn_Drop"
                                                        DragOver="KanbanColumn_DragOver"
                                                        Background="#F8FAFC"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="To Do"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#1D4ED8" />
                                                        <ListBox x:Name="KanbanToDoListBox"
                                                                 Grid.Row="1"
                                                                 Margin="0,10,0,0"
                                                                 MinHeight="320"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 PreviewMouseMove="KanbanTask_PreviewMouseMove">
                                                            <ListBox.ItemContainerStyle>
                                                                <Style TargetType="ListBoxItem">
                                                                    <Setter Property="Padding" Value="0" />
                                                                    <Setter Property="Margin" Value="0,0,0,10" />
                                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                                    <Setter Property="Cursor" Value="Hand" />
                                                                </Style>
                                                            </ListBox.ItemContainerStyle>
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="White"
                                                                            BorderBrush="#E2E8F0"
                                                                            BorderThickness="1"
                                                                            CornerRadius="8"
                                                                            Padding="10">
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding Title}"
                                                                                       FontWeight="SemiBold"
                                                                                       TextWrapping="Wrap"
                                                                                       Foreground="#0F172A" />
                                                                            <TextBlock Text="{Binding AssignedEmployee.FullName, TargetNullValue=Unassigned}"
                                                                                       Margin="0,6,0,0"
                                                                                       FontSize="12"
                                                                                       Foreground="#64748B" />
                                                                            <Border Style="{StaticResource BadgeBorderStyle}"
                                                                                    Margin="0,8,0,0"
                                                                                    HorizontalAlignment="Left"
                                                                                    Background="{Binding Priority, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Background}"
                                                                                    BorderBrush="{Binding Priority, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Border}">
                                                                                <TextBlock Text="{Binding Priority, Converter={StaticResource StatusBadgeConverter}}"
                                                                                           Foreground="{Binding Priority, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Foreground}"
                                                                                           FontSize="12"
                                                                                           FontWeight="SemiBold" />
                                                                            </Border>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </Grid>
                                                </Border>

                                                <Border Grid.Column="2"
                                                        Tag="In Progress"
                                                        AllowDrop="True"
                                                        Drop="KanbanColumn_Drop"
                                                        DragOver="KanbanColumn_DragOver"
                                                        Background="#F8FAFC"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="In Progress"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#9A3412" />
                                                        <ListBox x:Name="KanbanInProgressListBox"
                                                                 Grid.Row="1"
                                                                 Margin="0,10,0,0"
                                                                 MinHeight="320"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 PreviewMouseMove="KanbanTask_PreviewMouseMove"
                                                                 ItemContainerStyle="{Binding ElementName=KanbanToDoListBox, Path=ItemContainerStyle}"
                                                                 ItemTemplate="{Binding ElementName=KanbanToDoListBox, Path=ItemTemplate}" />
                                                    </Grid>
                                                </Border>

                                                <Border Grid.Column="4"
                                                        Tag="Review"
                                                        AllowDrop="True"
                                                        Drop="KanbanColumn_Drop"
                                                        DragOver="KanbanColumn_DragOver"
                                                        Background="#F8FAFC"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="Review"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#6D28D9" />
                                                        <ListBox x:Name="KanbanReviewListBox"
                                                                 Grid.Row="1"
                                                                 Margin="0,10,0,0"
                                                                 MinHeight="320"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 PreviewMouseMove="KanbanTask_PreviewMouseMove"
                                                                 ItemContainerStyle="{Binding ElementName=KanbanToDoListBox, Path=ItemContainerStyle}"
                                                                 ItemTemplate="{Binding ElementName=KanbanToDoListBox, Path=ItemTemplate}" />
                                                    </Grid>
                                                </Border>

                                                <Border Grid.Column="6"
                                                        Tag="Blocked"
                                                        AllowDrop="True"
                                                        Drop="KanbanColumn_Drop"
                                                        DragOver="KanbanColumn_DragOver"
                                                        Background="#F8FAFC"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="Blocked"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#991B1B" />
                                                        <ListBox x:Name="KanbanBlockedListBox"
                                                                 Grid.Row="1"
                                                                 Margin="0,10,0,0"
                                                                 MinHeight="320"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 PreviewMouseMove="KanbanTask_PreviewMouseMove"
                                                                 ItemContainerStyle="{Binding ElementName=KanbanToDoListBox, Path=ItemContainerStyle}"
                                                                 ItemTemplate="{Binding ElementName=KanbanToDoListBox, Path=ItemTemplate}" />
                                                    </Grid>
                                                </Border>

                                                <Border Grid.Column="8"
                                                        Tag="Done"
                                                        AllowDrop="True"
                                                        Drop="KanbanColumn_Drop"
                                                        DragOver="KanbanColumn_DragOver"
                                                        Background="#F8FAFC"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="Done"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#166534" />
                                                        <ListBox x:Name="KanbanDoneListBox"
                                                                 Grid.Row="1"
                                                                 Margin="0,10,0,0"
                                                                 MinHeight="320"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 PreviewMouseMove="KanbanTask_PreviewMouseMove"
                                                                 ItemContainerStyle="{Binding ElementName=KanbanToDoListBox, Path=ItemContainerStyle}"
                                                                 ItemTemplate="{Binding ElementName=KanbanToDoListBox, Path=ItemTemplate}" />
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </ScrollViewer>

                                        <TextBlock x:Name="KanbanEmptyTextBlock"
                                                   Grid.Row="2"
                                                   Text="No tasks found for the board."
                                                   Margin="0,10,0,0"
                                                   FontSize="13"
                                                   Foreground="#64748B"
                                                   Visibility="Collapsed" />
                                    </Grid>
                                </Border>
                            </TabItem>

                            <TabItem x:Name="DocumentsTab" Header="Documents">
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.25*" MinWidth="300" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="0.9*" MinWidth="260" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto">
                                        <Grid MinWidth="1600">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Project documents" Style="{StaticResource SectionTitleStyle}" />

                                                <TextBlock Text="Analyze project documents with file check, text extraction, and AI review."
                                                           Margin="0,4,0,0"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Foreground="#64748B" />

                                                <TextBlock x:Name="SelectedProjectForDocumentTextBlock"
                                                           Text="Select a project from the Projects tab first."
                                                           Margin="0,12,0,0"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Foreground="#334155" />
                                            </StackPanel>

                                            <DataGrid x:Name="DocumentsDataGrid"
                                                      Grid.Row="1"
                                                      MinHeight="300"
                                                      Margin="0,16,0,0"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      SelectionMode="Single"
                                                      SelectionChanged="DocumentsDataGrid_SelectionChanged"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                      BorderBrush="#E2E8F0"
                                                      BorderThickness="1">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="220" />
                                                    <DataGridTemplateColumn Header="Status" Width="120">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource BadgeBorderStyle}"
                                                                        Background="{Binding Status, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Background}"
                                                                        BorderBrush="{Binding Status, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Border}">
                                                                    <TextBlock Text="{Binding Status, Converter={StaticResource StatusBadgeConverter}}"
                                                                               Foreground="{Binding Status, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Foreground}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="AI policy" Width="150">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource BadgeBorderStyle}"
                                                                        Background="{Binding AIProcessingPolicy, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Background}"
                                                                        BorderBrush="{Binding AIProcessingPolicy, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Border}">
                                                                    <TextBlock Text="{Binding AIProcessingPolicy, Converter={StaticResource StatusBadgeConverter}}"
                                                                               Foreground="{Binding AIProcessingPolicy, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Foreground}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Check" Width="130">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource BadgeBorderStyle}"
                                                                        Background="{Binding FileCheckStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Background}"
                                                                        BorderBrush="{Binding FileCheckStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Border}">
                                                                    <TextBlock Text="{Binding FileCheckStatus, Converter={StaticResource StatusBadgeConverter}}"
                                                                               Foreground="{Binding FileCheckStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Foreground}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Text" Width="130">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource BadgeBorderStyle}"
                                                                        Background="{Binding TextExtractionStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Background}"
                                                                        BorderBrush="{Binding TextExtractionStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Border}">
                                                                    <TextBlock Text="{Binding TextExtractionStatus, Converter={StaticResource StatusBadgeConverter}}"
                                                                               Foreground="{Binding TextExtractionStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Foreground}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="AI" Width="130">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource BadgeBorderStyle}"
                                                                        Background="{Binding AIAnalysisStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Background}"
                                                                        BorderBrush="{Binding AIAnalysisStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Border}">
                                                                    <TextBlock Text="{Binding AIAnalysisStatus, Converter={StaticResource StatusBadgeConverter}}"
                                                                               Foreground="{Binding AIAnalysisStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Foreground}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="Provider" Binding="{Binding AIProviderName}" Width="120" />
                                                    <DataGridTemplateColumn Header="Review" Width="130">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource BadgeBorderStyle}"
                                                                        Background="{Binding AIReviewStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Background}"
                                                                        BorderBrush="{Binding AIReviewStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Border}">
                                                                    <TextBlock Text="{Binding AIReviewStatus, Converter={StaticResource StatusBadgeConverter}}"
                                                                               Foreground="{Binding AIReviewStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Foreground}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Risk" Width="110">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource BadgeBorderStyle}"
                                                                        Background="{Binding AIRiskLevel, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Background}"
                                                                        BorderBrush="{Binding AIRiskLevel, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Border}">
                                                                    <TextBlock Text="{Binding AIRiskLevel, Converter={StaticResource StatusBadgeConverter}}"
                                                                               Foreground="{Binding AIRiskLevel, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Foreground}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="Score" Binding="{Binding AIRiskScore}" Width="90" />
                                                    <DataGridTemplateColumn Header="Compliance" Width="150">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource BadgeBorderStyle}"
                                                                        Background="{Binding AIComplianceStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Background}"
                                                                        BorderBrush="{Binding AIComplianceStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Border}">
                                                                    <TextBlock Text="{Binding AIComplianceStatus, Converter={StaticResource StatusBadgeConverter}}"
                                                                               Foreground="{Binding AIComplianceStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Foreground}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="Analyzed" Binding="{Binding AnalyzedAt, StringFormat={}{0:dd.MM.yyyy}}" Width="110" />
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <TextBlock x:Name="DocumentsEmptyTextBlock"
                                                       Grid.Row="2"
                                                       Text="No documents for this project yet."
                                                       Margin="0,10,0,0"
                                                       FontSize="13"
                                                       Foreground="#64748B"
                                                       Visibility="Collapsed" />
                                        </Grid>
                                        </ScrollViewer>
                                    </Border>

                                    <GridSplitter Grid.Column="1"
                                                  Width="10"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"
                                                  ResizeBehavior="PreviousAndNext"
                                                  Background="Transparent"
                                                  ShowsPreview="True">
                                        <GridSplitter.Template>
                                            <ControlTemplate TargetType="GridSplitter">
                                                <Border Background="#D8E1EC"
                                                        Width="2"
                                                        CornerRadius="1"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,8" />
                                            </ControlTemplate>
                                        </GridSplitter.Template>
                                    </GridSplitter>

                                    <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <TextBlock Text="Document details" Style="{StaticResource SectionTitleStyle}" />

                                                <TextBlock Text="Add a document or update the selected document review status."
                                                           Margin="0,4,0,16"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Foreground="#64748B" />

                                                <Border Style="{StaticResource FormGroupStyle}" Margin="0,0,0,0">
                                                    <StackPanel>
                                                        <TextBlock Text="File"
                                                                   Style="{StaticResource FormGroupTitleStyle}" />

                                                        <TextBlock Text="File name" Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                        <TextBox x:Name="DocumentFileNameTextBox" Style="{StaticResource InputStyle}" />

                                                        <TextBlock Text="Shown in the document list; keep the extension visible."
                                                                   Style="{StaticResource HelperTextStyle}" />

                                                        <TextBlock Text="File path" Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                        <TextBox x:Name="DocumentFilePathTextBox" Style="{StaticResource InputStyle}" />

                                                        <TextBlock Text="The app checks this path before extracting text."
                                                                   Style="{StaticResource HelperTextStyle}" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Style="{StaticResource FormGroupStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="Review settings"
                                                                   Style="{StaticResource FormGroupTitleStyle}" />

                                                        <TextBlock Text="Approval and AI flow"
                                                                   Style="{StaticResource HelperTextStyle}" />

                                                        <StackPanel Margin="0,10,0,4" Orientation="Horizontal">
                                                            <Border Style="{StaticResource WorkflowStepStyle}" BorderBrush="#BFDBFE" Background="#EFF6FF">
                                                                <TextBlock Text="Uploaded" Style="{StaticResource WorkflowStepTextStyle}" Foreground="#1D4ED8" />
                                                            </Border>
                                                            <TextBlock Style="{StaticResource WorkflowArrowStyle}" />
                                                            <Border Style="{StaticResource WorkflowStepStyle}" BorderBrush="#FED7AA" Background="#FFF7ED">
                                                                <TextBlock Text="Review" Style="{StaticResource WorkflowStepTextStyle}" Foreground="#9A3412" />
                                                            </Border>
                                                            <TextBlock Style="{StaticResource WorkflowArrowStyle}" />
                                                            <Border Style="{StaticResource WorkflowStepStyle}" BorderBrush="#DDD6FE" Background="#F5F3FF">
                                                                <TextBlock Text="AI policy" Style="{StaticResource WorkflowStepTextStyle}" Foreground="#6D28D9" />
                                                            </Border>
                                                            <TextBlock Style="{StaticResource WorkflowArrowStyle}" />
                                                            <Border Style="{StaticResource WorkflowStepStyle}" BorderBrush="#BBF7D0" Background="#EAF8F0">
                                                                <TextBlock Text="Approved" Style="{StaticResource WorkflowStepTextStyle}" Foreground="#166534" />
                                                            </Border>
                                                        </StackPanel>

                                                        <TextBlock Text="Status" Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                        <ComboBox x:Name="DocumentStatusComboBox"
                                                                  Height="40"
                                                                  SelectedIndex="0">
                                                            <ComboBoxItem Content="Uploaded" />
                                                            <ComboBoxItem Content="In Review" />
                                                            <ComboBoxItem Content="Approved" />
                                                            <ComboBoxItem Content="Needs Update" />
                                                        </ComboBox>

                                                        <TextBlock Text="Use Needs Update when the document must be revised."
                                                                   Style="{StaticResource HelperTextStyle}" />

                                                        <TextBlock Text="AI processing policy" Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                        <ComboBox x:Name="DocumentAIProcessingPolicyComboBox"
                                                                  Height="40"
                                                                  SelectedIndex="0"
                                                                  SelectionChanged="DocumentAIProcessingPolicyComboBox_SelectionChanged">
                                                            <ComboBoxItem Content="Internal Only" />
                                                            <ComboBoxItem Content="External AI Allowed" />
                                                            <ComboBoxItem Content="Needs Approval" />
                                                            <ComboBoxItem Content="Blocked" />
                                                        </ComboBox>

                                                        <TextBlock x:Name="DocumentAIProcessingPolicyDescriptionTextBlock"
                                                                   Style="{StaticResource HelperTextStyle}"
                                                                   Text="Document stays in internal analysis and is not sent to an external AI service." />

                                                        <TextBlock Text="Notes" Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                        <TextBox x:Name="DocumentNotesTextBox"
                                                                 Height="84"
                                                                 Padding="10,8"
                                                                 TextWrapping="Wrap"
                                                                 AcceptsReturn="True"
                                                                 BorderBrush="#CBD5E1"
                                                                 BorderThickness="1" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Padding="12"
                                                        Margin="0,14,0,0"
                                                        Background="#F8FAFC"
                                                        BorderBrush="#CBD5E1"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <StackPanel>
                                                        <TextBlock Text="File check"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#0F172A" />

                                                        <TextBlock x:Name="DocumentFileCheckStatusTextBlock"
                                                                   Text="Not Checked"
                                                                   Margin="0,6,0,0"
                                                                   FontSize="13"
                                                                   Foreground="#334155" />

                                                        <TextBlock x:Name="DocumentFileCheckMessageTextBlock"
                                                                   Margin="0,8,0,0"
                                                                   FontSize="13"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="#64748B" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Padding="12"
                                                        Margin="0,14,0,0"
                                                        Background="#EFF6FF"
                                                        BorderBrush="#BFDBFE"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <StackPanel>
                                                        <TextBlock Text="AI analysis"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#1E3A8A" />

                                                        <TextBlock x:Name="DocumentAIStatusTextBlock"
                                                                   Text="Not Analyzed"
                                                                   Margin="0,6,0,0"
                                                                   FontSize="13"
                                                                   Foreground="#334155" />

                                                        <TextBlock x:Name="DocumentAIProviderTextBlock"
                                                                   Text="Provider: none"
                                                                   Margin="0,6,0,0"
                                                                   FontSize="13"
                                                                   Foreground="#334155" />

                                                        <TextBlock x:Name="DocumentAIRiskLevelTextBlock"
                                                                   Text="Risk: none"
                                                                   Margin="0,4,0,0"
                                                                   FontSize="13"
                                                                   Foreground="#334155" />

                                                        <TextBlock x:Name="DocumentAIRiskScoreTextBlock"
                                                                   Text="Risk score: 0"
                                                                   Margin="0,4,0,0"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#334155" />

                                                        <TextBlock x:Name="DocumentAIComplianceStatusTextBlock"
                                                                   Text="Compliance: none"
                                                                   Margin="0,4,0,0"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#334155" />

                                                        <TextBlock x:Name="DocumentAIReviewStatusTextBlock"
                                                                   Text="Review: Not Ready"
                                                                   Margin="0,4,0,0"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#334155" />

                                                        <TextBlock Text="Summary"
                                                                   Margin="0,10,0,4"
                                                                   Style="{StaticResource FieldLabelStyle}" />

                                                        <TextBox x:Name="DocumentAISummaryTextBox"
                                                                 Height="76"
                                                                 Padding="10,8"
                                                                 TextWrapping="Wrap"
                                                                 AcceptsReturn="True"
                                                                 IsReadOnly="True"
                                                                 BorderBrush="#CBD5E1"
                                                                 BorderThickness="1" />

                                                        <TextBlock Text="Risk notes"
                                                                   Margin="0,10,0,4"
                                                                   Style="{StaticResource FieldLabelStyle}" />

                                                        <TextBox x:Name="DocumentAIRiskNotesTextBox"
                                                                 Height="76"
                                                                 Padding="10,8"
                                                                 TextWrapping="Wrap"
                                                                 AcceptsReturn="True"
                                                                 IsReadOnly="True"
                                                                 BorderBrush="#CBD5E1"
                                                                 BorderThickness="1" />

                                                        <TextBlock Text="Recommendations"
                                                                   Margin="0,10,0,4"
                                                                   Style="{StaticResource FieldLabelStyle}" />

                                                        <TextBox x:Name="DocumentAIRecommendationsTextBox"
                                                                 Height="64"
                                                                 Padding="10,8"
                                                                 TextWrapping="Wrap"
                                                                 AcceptsReturn="True"
                                                                 IsReadOnly="True"
                                                                 BorderBrush="#CBD5E1"
                                                                 BorderThickness="1" />

                                                        <TextBlock Text="Detected issues"
                                                                   Margin="0,10,0,4"
                                                                   Style="{StaticResource FieldLabelStyle}" />

                                                        <TextBox x:Name="DocumentAIDetectedIssuesTextBox"
                                                                 Height="64"
                                                                 Padding="10,8"
                                                                 TextWrapping="Wrap"
                                                                 AcceptsReturn="True"
                                                                 IsReadOnly="True"
                                                                 BorderBrush="#CBD5E1"
                                                                 BorderThickness="1" />

                                                        <TextBlock Text="Policy violations"
                                                                   Margin="0,10,0,4"
                                                                   Style="{StaticResource FieldLabelStyle}" />

                                                        <TextBox x:Name="DocumentAIPolicyViolationsTextBox"
                                                                 Height="64"
                                                                 Padding="10,8"
                                                                 TextWrapping="Wrap"
                                                                 AcceptsReturn="True"
                                                                 IsReadOnly="True"
                                                                 BorderBrush="#CBD5E1"
                                                                 BorderThickness="1" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Padding="12"
                                                        Margin="0,14,0,0"
                                                        Background="#F0FDF4"
                                                        BorderBrush="#BBF7D0"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <StackPanel>
                                                        <TextBlock Text="Text extraction"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#166534" />

                                                        <TextBlock x:Name="DocumentTextExtractionStatusTextBlock"
                                                                   Text="Not Extracted"
                                                                   Margin="0,6,0,0"
                                                                   FontSize="13"
                                                                   Foreground="#334155" />

                                                        <TextBox x:Name="DocumentExtractedTextPreviewTextBox"
                                                                 Height="92"
                                                                 Margin="0,8,0,0"
                                                                 Padding="10,8"
                                                                 TextWrapping="Wrap"
                                                                 AcceptsReturn="True"
                                                                 IsReadOnly="True"
                                                                 BorderBrush="#CBD5E1"
                                                                 BorderThickness="1" />
                                                    </StackPanel>
                                                </Border>

                                                <Button x:Name="AddDocumentButton"
                                                        Content="Add document"
                                                        Margin="0,18,0,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Click="AddDocumentButton_Click" />

                                                <Button x:Name="UpdateDocumentStatusButton"
                                                        Content="Update status"
                                                        Margin="0,10,0,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        IsEnabled="False"
                                                        Click="UpdateDocumentStatusButton_Click" />

                                                <Button x:Name="AnalyzeDocumentButton"
                                                        Content="Analyze document"
                                                        Margin="0,14,0,0"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        IsEnabled="False"
                                                        Click="AnalyzeDocumentButton_Click" />

                                                <Button x:Name="ApproveExternalAIButton"
                                                        Content="Grant external AI approval"
                                                        Margin="0,10,0,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        IsEnabled="False"
                                                        Click="ApproveExternalAIButton_Click" />

                                                <Button x:Name="MarkAIReviewedButton"
                                                        Content="Mark AI analysis as reviewed"
                                                        Margin="0,10,0,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        IsEnabled="False"
                                                        Click="MarkAIReviewedButton_Click" />

                                                <Border Padding="12"
                                                        Margin="0,14,0,0"
                                                        Background="#F8FAFC"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <StackPanel>
                                                        <TextBlock Text="Advanced tools"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#334155" />

                                                        <Button x:Name="CheckDocumentFileButton"
                                                                Content="Check file"
                                                                Margin="0,10,0,0"
                                                                Style="{StaticResource SecondaryButtonStyle}"
                                                                IsEnabled="False"
                                                                Click="CheckDocumentFileButton_Click" />

                                                        <Button x:Name="ExtractDocumentTextButton"
                                                                Content="Extract text"
                                                                Margin="0,10,0,0"
                                                                Style="{StaticResource SecondaryButtonStyle}"
                                                                IsEnabled="False"
                                                                Click="ExtractDocumentTextButton_Click" />
                                                    </StackPanel>
                                                </Border>

                                                <Button Content="Clear"
                                                        Margin="0,10,0,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Click="ClearDocumentFormButton_Click" />

                                                <TextBlock x:Name="DocumentFormMessageTextBlock"
                                                           Margin="0,12,0,0"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Visibility="Collapsed" />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem x:Name="TeamTab" Header="Team">
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.25*" MinWidth="260" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="0.9*" MinWidth="240" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Team overview" Style="{StaticResource SectionTitleStyle}" />

                                                <TextBlock Text="Managers track availability, open workload, and backup coverage here."
                                                           Margin="0,4,0,0"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Foreground="#64748B" />
                                            </StackPanel>

                                            <DataGrid x:Name="EmployeesDataGrid"
                                                      Grid.Row="1"
                                                      MinHeight="320"
                                                      Margin="0,16,0,0"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      SelectionMode="Single"
                                                      SelectionChanged="EmployeesDataGrid_SelectionChanged"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      BorderBrush="#E2E8F0"
                                                      BorderThickness="1"
                                                      RowStyle="{StaticResource EmployeeWorkloadRowStyle}">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*" />
                                                    <DataGridTextColumn Header="Dept" Binding="{Binding Department}" Width="0.75*" />
                                                    <DataGridTemplateColumn Header="Status" Width="0.85*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource BadgeBorderStyle}"
                                                                        Background="{Binding AvailabilityStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Background}"
                                                                        BorderBrush="{Binding AvailabilityStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Border}">
                                                                    <TextBlock Text="{Binding AvailabilityStatus, Converter={StaticResource StatusBadgeConverter}}"
                                                                               Foreground="{Binding AvailabilityStatus, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Foreground}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               VerticalAlignment="Center" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="Open" Binding="{Binding OpenTaskCount}" Width="0.45*" />
                                                    <DataGridTextColumn Header="Next due" Binding="{Binding NextOpenTaskDueDate, StringFormat={}{0:dd.MM.yyyy}}" Width="0.7*" />
                                                    <DataGridTextColumn Header="Backup" Binding="{Binding BackupEmployeeName}" Width="0.9*" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>

                                    <GridSplitter Grid.Column="1"
                                                  Width="10"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"
                                                  ResizeBehavior="PreviousAndNext"
                                                  Background="Transparent"
                                                  ShowsPreview="True">
                                        <GridSplitter.Template>
                                            <ControlTemplate TargetType="GridSplitter">
                                                <Border Background="#D8E1EC"
                                                        Width="2"
                                                        CornerRadius="1"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,8" />
                                            </ControlTemplate>
                                        </GridSplitter.Template>
                                    </GridSplitter>

                                    <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <TextBlock Text="Employee details" Style="{StaticResource SectionTitleStyle}" />

                                                <TextBlock Text="Calisan bilgisi, izin araligi ve yerine bakabilecek kisi."
                                                           Margin="0,4,0,16"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Foreground="#64748B" />

                                                <Border Padding="12"
                                                        Margin="0,0,0,16"
                                                        Background="#EFF6FF"
                                                        BorderBrush="#BFDBFE"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <TextBlock x:Name="EmployeeWorkloadSummaryTextBlock"
                                                               Text="Select a team member from the list."
                                                               FontSize="13"
                                                               TextWrapping="Wrap"
                                                               Foreground="#1E3A8A" />
                                                </Border>

                                                <Border Style="{StaticResource FormGroupStyle}" Margin="0,0,0,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Profile"
                                                                   Style="{StaticResource FormGroupTitleStyle}" />

                                                        <TextBlock Text="Full name" Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                        <TextBox x:Name="EmployeeFullNameTextBox" Style="{StaticResource InputStyle}" />

                                                        <TextBlock Text="Email" Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                        <TextBox x:Name="EmployeeEmailTextBox" Style="{StaticResource InputStyle}" />

                                                        <TextBlock Text="Used for sign-in links and assignment context."
                                                                   Style="{StaticResource HelperTextStyle}" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Style="{StaticResource FormGroupStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="Role and capacity"
                                                                   Style="{StaticResource FormGroupTitleStyle}" />

                                                        <TextBlock Text="Department" Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                        <TextBox x:Name="EmployeeDepartmentTextBox" Style="{StaticResource InputStyle}" />

                                                        <TextBlock Text="Role" Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                        <TextBox x:Name="EmployeeRoleTextBox" Style="{StaticResource InputStyle}" />

                                                        <TextBlock Text="Availability" Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                        <ComboBox x:Name="EmployeeAvailabilityComboBox"
                                                                  Height="40"
                                                                  SelectedIndex="0">
                                                            <ComboBoxItem Content="Available" />
                                                            <ComboBoxItem Content="Busy" />
                                                            <ComboBoxItem Content="On Leave" />
                                                            <ComboBoxItem Content="Emergency Cover" />
                                                        </ComboBox>

                                                        <TextBlock Text="Availability affects workload warnings and coverage planning."
                                                                   Style="{StaticResource HelperTextStyle}" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Style="{StaticResource FormGroupStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="Coverage"
                                                                   Style="{StaticResource FormGroupTitleStyle}" />

                                                        <Grid Margin="0,14,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="10" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="Leave start" Style="{StaticResource FieldLabelStyle}" />
                                                                <DatePicker x:Name="EmployeeLeaveStartDatePicker" Height="40" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="Leave end" Style="{StaticResource FieldLabelStyle}" />
                                                                <DatePicker x:Name="EmployeeLeaveEndDatePicker" Height="40" />
                                                            </StackPanel>
                                                        </Grid>

                                                        <TextBlock Text="Skills / notes" Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                        <TextBox x:Name="EmployeeSkillsTextBox"
                                                                 Height="70"
                                                                 Padding="10,8"
                                                                 TextWrapping="Wrap"
                                                                 AcceptsReturn="True"
                                                                 BorderBrush="#CBD5E1"
                                                                 BorderThickness="1" />

                                                        <TextBlock Text="Emergency backup" Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                        <TextBox x:Name="EmployeeBackupTextBox" Style="{StaticResource InputStyle}" />

                                                        <TextBlock Text="Backup is shown when coverage may be needed."
                                                                   Style="{StaticResource HelperTextStyle}" />
                                                    </StackPanel>
                                                </Border>

                                                <Button x:Name="AddEmployeeButton"
                                                        Content="Add employee"
                                                        Margin="0,18,0,0"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Click="AddEmployeeButton_Click" />

                                                <UniformGrid Columns="2" Margin="0,10,0,0">
                                                    <Button x:Name="UpdateEmployeeButton"
                                                            Content="Update"
                                                            Margin="0,0,5,0"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            IsEnabled="False"
                                                            Click="UpdateEmployeeButton_Click" />

                                                    <Button Content="Clear"
                                                            Margin="5,0,0,0"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Click="ClearEmployeeFormButton_Click" />
                                                </UniformGrid>

                                                <TextBlock x:Name="EmployeeFormMessageTextBlock"
                                                           Margin="0,12,0,0"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Visibility="Collapsed" />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem x:Name="UsersTab" Header="Users">
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" MinWidth="300" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="0.9*" MinWidth="260" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="User accounts" Style="{StaticResource SectionTitleStyle}" />

                                                <TextBlock Text="Manage users, roles, and employee links."
                                                           Margin="0,4,0,0"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Foreground="#64748B" />
                                            </StackPanel>

                                            <DataGrid x:Name="UserAccountsDataGrid"
                                                      Grid.Row="1"
                                                      MinHeight="320"
                                                      Margin="0,16,0,0"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      SelectionMode="Single"
                                                      SelectionChanged="UserAccountsDataGrid_SelectionChanged"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      BorderBrush="#E2E8F0"
                                                      BorderThickness="1">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.35*" />
                                                    <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="0.7*" />
                                                    <DataGridTextColumn Header="Employee" Binding="{Binding EmployeeName}" Width="1*" />
                                                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive, Mode=OneWay}" Width="0.55*" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>

                                    <GridSplitter Grid.Column="1"
                                                  Width="10"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"
                                                  ResizeBehavior="PreviousAndNext"
                                                  Background="Transparent"
                                                  ShowsPreview="True">
                                        <GridSplitter.Template>
                                            <ControlTemplate TargetType="GridSplitter">
                                                <Border Background="#D8E1EC"
                                                        Width="2"
                                                        CornerRadius="1"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,8" />
                                            </ControlTemplate>
                                        </GridSplitter.Template>
                                    </GridSplitter>

                                    <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <TextBlock Text="User details" Style="{StaticResource SectionTitleStyle}" />

                                                <TextBlock Text="Create users, assign roles, link employees, or reset passwords."
                                                           Margin="0,4,0,16"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Foreground="#64748B" />

                                                <Border Style="{StaticResource FormGroupStyle}" Margin="0,0,0,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Account"
                                                                   Style="{StaticResource FormGroupTitleStyle}" />

                                                        <TextBlock Text="Email" Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                        <TextBox x:Name="UserEmailTextBox" Style="{StaticResource InputStyle}" />

                                                        <TextBlock Text="This is the sign-in email and must be unique."
                                                                   Style="{StaticResource HelperTextStyle}" />

                                                        <CheckBox x:Name="UserIsActiveCheckBox"
                                                                  Content="Active user"
                                                                  Margin="0,14,0,0"
                                                                  IsChecked="True"
                                                                  FontWeight="SemiBold"
                                                                  Foreground="#334155" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Style="{StaticResource FormGroupStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="Access"
                                                                   Style="{StaticResource FormGroupTitleStyle}" />

                                                        <TextBlock Text="Role" Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                        <ComboBox x:Name="UserRoleComboBox"
                                                                  Height="40"
                                                                  SelectedIndex="2">
                                                            <ComboBoxItem Content="Admin" />
                                                            <ComboBoxItem Content="Manager" />
                                                            <ComboBoxItem Content="Staff" />
                                                        </ComboBox>

                                                        <TextBlock Text="Role controls which tabs and actions are available."
                                                                   Style="{StaticResource HelperTextStyle}" />

                                                        <TextBlock Text="Employee link" Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                        <ComboBox x:Name="UserEmployeeComboBox"
                                                                  Height="40"
                                                                  DisplayMemberPath="FullName"
                                                                  SelectedValuePath="Id" />

                                                        <TextBlock Text="Optional for Admin/Manager, useful for Staff task filtering."
                                                                   Style="{StaticResource HelperTextStyle}" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Style="{StaticResource FormGroupStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="Password"
                                                                   Style="{StaticResource FormGroupTitleStyle}" />

                                                        <TextBlock Text="Password / reset"
                                                                   Margin="0,14,0,6"
                                                                   Style="{StaticResource FieldLabelStyle}" />

                                                        <PasswordBox x:Name="NewUserPasswordBox"
                                                                     Height="40"
                                                                     Padding="12,0"
                                                                     VerticalContentAlignment="Center"
                                                                     BorderBrush="#CBD5E1"
                                                                     BorderThickness="1" />

                                                        <TextBlock Text="Required for new users; used as reset value for existing users."
                                                                   Style="{StaticResource HelperTextStyle}" />
                                                    </StackPanel>
                                                </Border>

                                                <Button x:Name="AddUserButton"
                                                        Content="Add user"
                                                        Margin="0,18,0,0"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Click="AddUserButton_Click" />

                                                <Button x:Name="UpdateUserButton"
                                                        Content="Update user"
                                                        Margin="0,10,0,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        IsEnabled="False"
                                                        Click="UpdateUserButton_Click" />

                                                <Button x:Name="ResetUserPasswordButton"
                                                        Content="Reset password"
                                                        Margin="0,10,0,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        IsEnabled="False"
                                                        Click="ResetUserPasswordButton_Click" />

                                                <Button Content="Clear"
                                                        Margin="0,10,0,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Click="ClearUserFormButton_Click" />

                                                <TextBlock x:Name="UserFormMessageTextBlock"
                                                           Margin="0,12,0,0"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Visibility="Collapsed" />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem x:Name="OverviewTab" Header="Overview">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel Margin="0,12,0,0">
                                        <StackPanel Margin="0,0,0,16">
                                            <Border Style="{StaticResource MetricCardStyle}" Background="#EFF6FF" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <DockPanel LastChildFill="False">
                                                        <TextBlock Text="Project progress"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#1E3A8A" />
                                                        <TextBlock x:Name="OverviewProjectProgressTextBlock"
                                                                   DockPanel.Dock="Right"
                                                                   Text="0%"
                                                                   FontSize="26"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#1D4ED8" />
                                                    </DockPanel>
                                                    <ProgressBar x:Name="OverviewProjectProgressBar"
                                                                 Height="7"
                                                                 Margin="0,12,0,0"
                                                                 Minimum="0"
                                                                 Maximum="100" />
                                                    <TextBlock x:Name="OverviewProjectProgressDetailTextBlock"
                                                               Text="0/0 projects completed"
                                                               Margin="0,8,0,0"
                                                               FontSize="12"
                                                               Foreground="#64748B" />
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource MetricCardStyle}" Background="#ECFDF5" BorderBrush="#BBF7D0" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <DockPanel LastChildFill="False">
                                                        <TextBlock Text="Task completion"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#166534" />
                                                        <TextBlock x:Name="OverviewTaskCompletionTextBlock"
                                                                   DockPanel.Dock="Right"
                                                                   Text="0%"
                                                                   FontSize="26"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#15803D" />
                                                    </DockPanel>
                                                    <ProgressBar x:Name="OverviewTaskCompletionBar"
                                                                 Height="7"
                                                                 Margin="0,12,0,0"
                                                                 Minimum="0"
                                                                 Maximum="100" />
                                                    <TextBlock x:Name="OverviewTaskCompletionDetailTextBlock"
                                                               Text="0/0 tasks done"
                                                               Margin="0,8,0,0"
                                                               FontSize="12"
                                                               Foreground="#64748B" />
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource MetricCardStyle}" Background="#F5F3FF" BorderBrush="#DDD6FE">
                                                <StackPanel>
                                                    <DockPanel LastChildFill="False">
                                                        <TextBlock Text="AI usage"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#6D28D9" />
                                                        <TextBlock x:Name="OverviewAIUsageTextBlock"
                                                                   DockPanel.Dock="Right"
                                                                   Text="0%"
                                                                   FontSize="26"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#6D28D9" />
                                                    </DockPanel>
                                                    <ProgressBar x:Name="OverviewAIUsageBar"
                                                                 Height="7"
                                                                 Margin="0,12,0,0"
                                                                 Minimum="0"
                                                                 Maximum="100" />
                                                    <TextBlock x:Name="OverviewAIUsageDetailTextBlock"
                                                               Text="0/0 documents analyzed"
                                                               Margin="0,8,0,0"
                                                               FontSize="12"
                                                               Foreground="#64748B" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,16">
                                            <Border Style="{StaticResource SectionCardStyle}" Margin="0">
                                                <StackPanel>
                                                    <TextBlock Text="Workload chart" Style="{StaticResource SectionTitleStyle}" />
                                                    <DataGrid x:Name="OverviewWorkloadDataGrid"
                                                              Height="190"
                                                              Margin="0,12,0,0"
                                                              AutoGenerateColumns="False"
                                                              CanUserAddRows="False"
                                                              IsReadOnly="True"
                                                              HeadersVisibility="Column"
                                                              GridLinesVisibility="Horizontal"
                                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                              BorderBrush="#E2E8F0"
                                                              BorderThickness="1">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Member" Binding="{Binding Name}" Width="1.1*" />
                                                            <DataGridTextColumn Header="Role" Binding="{Binding RoleText}" Width="1.5*" />
                                                            <DataGridTextColumn Header="Open tasks" Binding="{Binding OpenTaskText}" Width="1.1*" />
                                                            <DataGridTextColumn Header="Load" Binding="{Binding WorkloadPercent, StringFormat={}{0}%}" Width="0.7*" />
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource SectionCardStyle}" Margin="0,12,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Overdue heatmap" Style="{StaticResource SectionTitleStyle}" />
                                                    <DataGrid x:Name="OverviewHeatmapDataGrid"
                                                              Height="190"
                                                              Margin="0,12,0,0"
                                                              AutoGenerateColumns="False"
                                                              CanUserAddRows="False"
                                                              IsReadOnly="True"
                                                              HeadersVisibility="Column"
                                                              GridLinesVisibility="Horizontal"
                                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                              BorderBrush="#E2E8F0"
                                                              BorderThickness="1">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Project" Binding="{Binding ProjectName}" Width="1.6*" />
                                                            <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="1.2*" />
                                                            <DataGridTextColumn Header="Overdue" Binding="{Binding OverdueText}" Width="1*" />
                                                            <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="0.8*" />
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                    <TextBlock x:Name="OverviewHeatmapEmptyTextBlock"
                                                               Text="No overdue tasks."
                                                               Margin="0,8,0,0"
                                                               FontSize="12"
                                                               Foreground="#64748B" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,16">
                                            <Border Style="{StaticResource SectionCardStyle}" Margin="0">
                                                <StackPanel>
                                                    <TextBlock Text="Team productivity" Style="{StaticResource SectionTitleStyle}" />
                                                    <DataGrid x:Name="OverviewProductivityDataGrid"
                                                              Height="190"
                                                              Margin="0,12,0,0"
                                                              AutoGenerateColumns="False"
                                                              CanUserAddRows="False"
                                                              IsReadOnly="True"
                                                              HeadersVisibility="Column"
                                                              GridLinesVisibility="Horizontal"
                                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                              BorderBrush="#E2E8F0"
                                                              BorderThickness="1">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Member" Binding="{Binding Name}" Width="1.4*" />
                                                            <DataGridTextColumn Header="Done" Binding="{Binding CompletionText}" Width="1.6*" />
                                                            <DataGridTextColumn Header="Completion" Binding="{Binding CompletionPercent, StringFormat={}{0}%}" Width="1*" />
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                    <TextBlock x:Name="OverviewProductivityEmptyTextBlock"
                                                               Text="No task assignments for team productivity yet."
                                                               Margin="0,8,0,0"
                                                               FontSize="12"
                                                               Foreground="#64748B" />
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource SectionCardStyle}" Margin="0,12,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="AI usage metrics" Style="{StaticResource SectionTitleStyle}" />
                                                    <DataGrid x:Name="OverviewAIMetricsDataGrid"
                                                              Height="190"
                                                              Margin="0,12,0,0"
                                                              AutoGenerateColumns="False"
                                                              CanUserAddRows="False"
                                                              IsReadOnly="True"
                                                              HeadersVisibility="Column"
                                                              GridLinesVisibility="Horizontal"
                                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                              BorderBrush="#E2E8F0"
                                                              BorderThickness="1">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Metric" Binding="{Binding Title}" Width="1.1*" />
                                                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="0.8*" />
                                                            <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="1.8*" />
                                                            <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="0.8*" />
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <Border Style="{StaticResource SectionCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Due soon" Style="{StaticResource SectionTitleStyle}" />

                                <TextBlock x:Name="DueSoonNotificationTextBlock"
                                           Text="No projects due in the next 7 days."
                                           Margin="0,8,0,0"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Foreground="#64748B" />

                                <DataGrid x:Name="DueSoonProjectsDataGrid"
                                          Height="110"
                                          Margin="0,10,0,0"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          BorderBrush="#E2E8F0"
                                          BorderThickness="1">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Project" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="Customer" Binding="{Binding Customer.CompanyName}" Width="*" />
                                        <DataGridTextColumn Header="Due" Binding="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy}}" Width="0.8*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SectionCardStyle}" Margin="0">
                                            <StackPanel>
                                                <TextBlock Text="All projects" Style="{StaticResource SectionTitleStyle}" />

                                <DataGrid x:Name="AllProjectsDataGrid"
                                          Height="150"
                                          Margin="0,10,0,0"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          BorderBrush="#E2E8F0"
                                          BorderThickness="1">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Project" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="Customer" Binding="{Binding Customer.CompanyName}" Width="*" />
                                        <DataGridTemplateColumn Header="Status" Width="0.8*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource BadgeBorderStyle}"
                                                            Background="{Binding Status, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Background}"
                                                            BorderBrush="{Binding Status, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Border}">
                                                        <TextBlock Text="{Binding Status, Converter={StaticResource StatusBadgeConverter}}"
                                                                   Foreground="{Binding Status, Converter={StaticResource StatusBadgeConverter}, ConverterParameter=Foreground}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Due" Binding="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy}}" Width="0.8*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>

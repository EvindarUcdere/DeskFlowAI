<Window x:Class="DeskFlowAI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeskFlow AI"
        Width="1160"
        Height="720"
        MinWidth="900"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#334155" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D8E1EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#334155" />
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="Background" Value="#FAFCFF" />
            <Setter Property="BorderBrush" Value="#D8E1EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1F2937" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="#EEF3F8"
                                BorderBrush="#D8E1EC"
                                BorderThickness="1"
                                CornerRadius="8,8,0,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="White" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#2563EB" />
                                <Setter Property="Foreground" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#EEF3F8">
        <Grid x:Name="LoginView">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#17324D"
                    Padding="56">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="DeskFlow AI"
                               FontSize="42"
                               FontWeight="SemiBold"
                               Foreground="White" />

                    <TextBlock Text="Musteri, proje, gorev ve belge sureclerini tek masaustu uygulamasinda yonet."
                               Margin="0,18,0,0"
                               FontSize="18"
                               LineHeight="28"
                               TextWrapping="Wrap"
                               Foreground="#D9E6F2" />

                    <Border Margin="0,42,0,0"
                            Padding="18"
                            Background="#24445F"
                            BorderBrush="#3F6380"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Demo kullanici"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="White" />

                            <TextBlock Text="admin, manager veya staff @deskflow.ai / Admin123"
                                       Margin="0,8,0,0"
                                       FontSize="14"
                                       Foreground="#CFE0EF" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <Border MaxWidth="420"
                        Margin="56"
                        Padding="34"
                        Background="White"
                        BorderBrush="#D8E1EC"
                        BorderThickness="1"
                        CornerRadius="8"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Sign in"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937" />

                        <TextBlock Text="Sirket calisma alanina giris yap."
                                   Margin="0,8,0,28"
                                   FontSize="15"
                                   Foreground="#64748B" />

                        <TextBlock Text="Email" Style="{StaticResource FieldLabelStyle}" />

                        <TextBox x:Name="EmailTextBox"
                                 Style="{StaticResource InputStyle}"
                                 Text="admin@deskflow.ai" />

                        <TextBlock Text="Password"
                                   Margin="0,18,0,6"
                                   Style="{StaticResource FieldLabelStyle}" />

                        <PasswordBox x:Name="PasswordBox"
                                     Height="42"
                                     Padding="12,0"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="#CBD5E1"
                                     BorderThickness="1"
                                     Password="Admin123"
                                     KeyDown="PasswordBox_KeyDown" />

                        <TextBlock x:Name="LoginErrorTextBlock"
                                   Margin="0,14,0,0"
                                   FontSize="13"
                                   Foreground="#DC2626"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed" />

                        <Button Content="Sign in"
                                Height="42"
                                Margin="0,24,0,0"
                                Background="#2563EB"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Click="SignInButton_Click" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="DashboardView" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="72" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="#D8E1EC"
                    BorderThickness="0,0,0,1"
                    Padding="28,0">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left"
                                VerticalAlignment="Center">
                        <TextBlock Text="DeskFlow AI"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937" />

                        <TextBlock x:Name="SignedInUserTextBlock"
                                   Margin="0,3,0,0"
                                   FontSize="13"
                                   Foreground="#64748B" />
                    </StackPanel>

                    <Button DockPanel.Dock="Right"
                            Content="Sign out"
                            Width="96"
                            Height="36"
                            Margin="0,18,0,18"
                            Click="SignOutButton_Click" />
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Dashboard"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#1F2937" />

                    <TextBlock Text="Operasyon ozeti ve bekleyen isler."
                               Margin="0,6,0,16"
                               FontSize="15"
                               Foreground="#64748B" />
                </StackPanel>

                <UniformGrid Grid.Row="1"
                             Columns="4"
                             Rows="1"
                             Margin="0,0,0,18"
                             VerticalAlignment="Top">
                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Aktif projeler" Foreground="#64748B" />
                            <TextBlock x:Name="ActiveProjectsTextBlock" Text="0" Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" Foreground="#1F2937" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Acik gorevler" Foreground="#64748B" />
                            <TextBlock x:Name="OpenTasksTextBlock" Text="0" Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" Foreground="#1F2937" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Geciken isler" Foreground="#64748B" />
                            <TextBlock x:Name="OverdueTasksTextBlock" Text="0" Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" Foreground="#B91C1C" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel>
                            <TextBlock Text="AI bekleyen belgeler" Foreground="#64748B" />
                            <TextBlock x:Name="PendingAiDocumentsTextBlock" Text="0" Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" Foreground="#1F2937" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.75*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="18"
                            Background="White"
                            BorderBrush="#D8E1EC"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="0,0,18,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="2*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Margin="0,0,0,14">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="Customers"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#1F2937" />

                                    <TextBlock Text="Sirket musterilerini sahte veriyle listeliyoruz."
                                               Margin="0,4,0,0"
                                               FontSize="13"
                                               Foreground="#64748B" />
                                </StackPanel>

                                <Button x:Name="DeleteCustomerButton"
                                        DockPanel.Dock="Right"
                                        Content="Delete selected"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="DeleteCustomerButton_Click" />
                            </DockPanel>

                            <DockPanel Grid.Row="1"
                                       Margin="0,0,0,12">
                                <Button DockPanel.Dock="Right"
                                        Content="Clear search"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="ClearCustomerSearchButton_Click" />

                                <TextBox x:Name="CustomerSearchTextBox"
                                         Height="38"
                                         Padding="12,0"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         BorderBrush="#CBD5E1"
                                         BorderThickness="1"
                                         TextChanged="CustomerSearchTextBox_TextChanged" />
                            </DockPanel>

                            <DataGrid x:Name="CustomersDataGrid"
                                      Grid.Row="2"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionChanged="CustomersDataGrid_SelectionChanged"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderBrush="#E2E8F0"
                                      BorderThickness="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Company" Binding="{Binding CompanyName}" Width="*" />
                                    <DataGridTextColumn Header="Contact" Binding="{Binding ContactName}" Width="*" />
                                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.3*" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.7*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Grid.Row="3"
                                       Text="Audit log"
                                       Margin="0,14,0,8"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#1F2937" />

                            <DataGrid x:Name="AuditLogsDataGrid"
                                      Grid.Row="4"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderBrush="#E2E8F0"
                                      BorderThickness="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding OccurredAt, StringFormat={}{0:HH:mm:ss}}" Width="0.7*" />
                                    <DataGridTextColumn Header="Actor" Binding="{Binding ActorEmail}" Width="1.2*" />
                                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="0.8*" />
                                    <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="14"
                            Background="White"
                            BorderBrush="#D8E1EC"
                            BorderThickness="1"
                            CornerRadius="8">
                        <TabControl>
                            <TabItem Header="Customer">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="0,12,0,0">
                                <Border Style="{StaticResource SectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock x:Name="CustomerFormTitleTextBlock"
                                                   Text="Add customer"
                                                   Style="{StaticResource SectionTitleStyle}" />

                                        <TextBlock Text="Company"
                                                   Margin="0,16,0,6"
                                                   Style="{StaticResource FieldLabelStyle}" />

                                        <TextBox x:Name="CustomerCompanyTextBox"
                                                 Style="{StaticResource InputStyle}" />

                                        <TextBlock Text="Contact"
                                                   Margin="0,12,0,6"
                                                   Style="{StaticResource FieldLabelStyle}" />

                                        <TextBox x:Name="CustomerContactTextBox"
                                                 Style="{StaticResource InputStyle}" />

                                        <TextBlock Text="Email"
                                                   Margin="0,12,0,6"
                                                   Style="{StaticResource FieldLabelStyle}" />

                                        <TextBox x:Name="CustomerEmailTextBox"
                                                 Style="{StaticResource InputStyle}" />

                                        <TextBlock x:Name="CustomerFormMessageTextBlock"
                                                   Margin="0,12,0,0"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   Visibility="Collapsed" />

                                        <Button x:Name="AddCustomerButton"
                                                Content="Add customer"
                                                Margin="0,18,0,0"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Click="AddCustomerButton_Click" />

                                        <UniformGrid Columns="2"
                                                     Margin="0,10,0,0">
                                            <Button x:Name="UpdateCustomerButton"
                                                    Content="Update"
                                                    Margin="0,0,5,0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Click="UpdateCustomerButton_Click" />

                                            <Button Content="Clear"
                                                    Margin="5,0,0,0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Click="ClearCustomerFormButton_Click" />
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="Projects">
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.3*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="0.9*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Project list" Style="{StaticResource SectionTitleStyle}" />

                                                <TextBlock Text="Tum projeleri veya secili customer projelerini teslim tarihine gore gosterir."
                                                           Margin="0,4,0,0"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Foreground="#64748B" />

                                                <TextBlock x:Name="SelectedCustomerForProjectTextBlock"
                                                           Text="Once listeden bir customer sec."
                                                           Margin="0,10,0,0"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Foreground="#334155" />
                                            </StackPanel>

                                            <DataGrid x:Name="ProjectsDataGrid"
                                                      Grid.Row="1"
                                                      MinHeight="260"
                                                      Margin="0,16,0,0"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      SelectionMode="Single"
                                                      SelectionChanged="ProjectsDataGrid_SelectionChanged"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      BorderBrush="#E2E8F0"
                                                      BorderThickness="1">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Project" Binding="{Binding Name}" Width="*" />
                                                    <DataGridTextColumn Header="Customer" Binding="{Binding Customer.CompanyName}" Width="*" />
                                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.8*" />
                                                    <DataGridTextColumn Header="Due" Binding="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy}}" Width="0.75*" />
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <TextBlock x:Name="ProjectsEmptyTextBlock"
                                                       Grid.Row="2"
                                                       Text="Bu customer icin henuz proje yok."
                                                       Margin="0,10,0,0"
                                                       FontSize="13"
                                                       Foreground="#64748B"
                                                       Visibility="Collapsed" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <StackPanel>
                                            <TextBlock Text="Project details" Style="{StaticResource SectionTitleStyle}" />

                                            <TextBlock Text="Yeni proje ekle veya listeden sectigin projenin durumunu guncelle."
                                                       Margin="0,4,0,16"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"
                                                       Foreground="#64748B" />

                                            <TextBlock Text="Project name"
                                                       Style="{StaticResource FieldLabelStyle}" />

                                            <TextBox x:Name="ProjectNameTextBox"
                                                     Style="{StaticResource InputStyle}" />

                                            <TextBlock Text="Status"
                                                       Margin="0,12,0,6"
                                                       Style="{StaticResource FieldLabelStyle}" />

                                            <ComboBox x:Name="ProjectStatusComboBox"
                                                      Height="38"
                                                      SelectedIndex="0">
                                                <ComboBoxItem Content="Planning" />
                                                <ComboBoxItem Content="Active" />
                                                <ComboBoxItem Content="On Hold" />
                                                <ComboBoxItem Content="Completed" />
                                            </ComboBox>

                                            <TextBlock Text="Due date"
                                                       Margin="0,12,0,6"
                                                       Style="{StaticResource FieldLabelStyle}" />

                                            <DatePicker x:Name="ProjectDueDatePicker"
                                                        Height="38" />

                                            <Button x:Name="AddProjectButton"
                                                    Content="Add project"
                                                    Margin="0,18,0,0"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Click="AddProjectButton_Click" />

                                            <Button x:Name="UpdateProjectStatusButton"
                                                    Content="Update project status"
                                                    Margin="0,10,0,0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    IsEnabled="False"
                                                    Click="UpdateProjectStatusButton_Click" />

                                            <TextBlock x:Name="ProjectFormMessageTextBlock"
                                                       Margin="0,12,0,0"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"
                                                       Visibility="Collapsed" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Tasks">
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.25*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="0.95*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Task list" Style="{StaticResource SectionTitleStyle}" />

                                                <TextBlock Text="Secili project icindeki gorevler teslim tarihine ve oncelige gore siralanir."
                                                           Margin="0,4,0,0"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Foreground="#64748B" />

                                                <TextBlock x:Name="SelectedProjectForTaskTextBlock"
                                                           Text="Once Projects sekmesinden bir project sec."
                                                           Margin="0,10,0,0"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Foreground="#334155" />
                                            </StackPanel>

                                            <DataGrid x:Name="TasksDataGrid"
                                                      Grid.Row="1"
                                                      MinHeight="260"
                                                      Margin="0,16,0,0"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      SelectionMode="Single"
                                                      SelectionChanged="TasksDataGrid_SelectionChanged"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      BorderBrush="#E2E8F0"
                                                      BorderThickness="1">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Task" Binding="{Binding Title}" Width="*" />
                                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.8*" />
                                                    <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="0.75*" />
                                                    <DataGridTextColumn Header="Due" Binding="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy}}" Width="0.75*" />
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <TextBlock x:Name="TasksEmptyTextBlock"
                                                       Grid.Row="2"
                                                       Text="Bu project icin henuz task yok."
                                                       Margin="0,10,0,0"
                                                       FontSize="13"
                                                       Foreground="#64748B"
                                                       Visibility="Collapsed" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <StackPanel>
                                            <TextBlock Text="Task details" Style="{StaticResource SectionTitleStyle}" />

                                            <TextBlock Text="Yeni gorev ekle veya secili gorevin is akis bilgilerini guncelle."
                                                       Margin="0,4,0,16"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"
                                                       Foreground="#64748B" />

                                            <TextBlock Text="Task title"
                                                       Style="{StaticResource FieldLabelStyle}" />

                                            <TextBox x:Name="TaskTitleTextBox"
                                                     Style="{StaticResource InputStyle}" />

                                            <TextBlock Text="Status"
                                                       Margin="0,12,0,6"
                                                       Style="{StaticResource FieldLabelStyle}" />

                                            <ComboBox x:Name="TaskStatusComboBox"
                                                      Height="38"
                                                      SelectedIndex="0">
                                                <ComboBoxItem Content="To Do" />
                                                <ComboBoxItem Content="In Progress" />
                                                <ComboBoxItem Content="Blocked" />
                                                <ComboBoxItem Content="Done" />
                                            </ComboBox>

                                            <TextBlock Text="Priority"
                                                       Margin="0,12,0,6"
                                                       Style="{StaticResource FieldLabelStyle}" />

                                            <ComboBox x:Name="TaskPriorityComboBox"
                                                      Height="38"
                                                      SelectedIndex="1">
                                                <ComboBoxItem Content="Low" />
                                                <ComboBoxItem Content="Normal" />
                                                <ComboBoxItem Content="High" />
                                                <ComboBoxItem Content="Critical" />
                                            </ComboBox>

                                            <TextBlock Text="Due date"
                                                       Margin="0,12,0,6"
                                                       Style="{StaticResource FieldLabelStyle}" />

                                            <DatePicker x:Name="TaskDueDatePicker"
                                                        Height="38" />

                                            <Button x:Name="AddTaskButton"
                                                    Content="Add task"
                                                    Margin="0,18,0,0"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Click="AddTaskButton_Click" />

                                            <Button x:Name="UpdateTaskButton"
                                                    Content="Update task"
                                                    Margin="0,10,0,0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    IsEnabled="False"
                                                    Click="UpdateTaskButton_Click" />

                                            <TextBlock x:Name="TaskFormMessageTextBlock"
                                                       Margin="0,12,0,0"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"
                                                       Visibility="Collapsed" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Overview">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="0,12,0,0">
                                        <Border Style="{StaticResource SectionCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Due soon" Style="{StaticResource SectionTitleStyle}" />

                                <TextBlock x:Name="DueSoonNotificationTextBlock"
                                           Text="Son 7 gun icinde teslimi olan proje yok."
                                           Margin="0,8,0,0"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Foreground="#64748B" />

                                <DataGrid x:Name="DueSoonProjectsDataGrid"
                                          Height="110"
                                          Margin="0,10,0,0"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          BorderBrush="#E2E8F0"
                                          BorderThickness="1">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Project" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="Customer" Binding="{Binding Customer.CompanyName}" Width="*" />
                                        <DataGridTextColumn Header="Due" Binding="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy}}" Width="0.8*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SectionCardStyle}" Margin="0">
                                            <StackPanel>
                                                <TextBlock Text="All projects" Style="{StaticResource SectionTitleStyle}" />

                                <DataGrid x:Name="AllProjectsDataGrid"
                                          Height="150"
                                          Margin="0,10,0,0"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          BorderBrush="#E2E8F0"
                                          BorderThickness="1">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Project" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="Customer" Binding="{Binding Customer.CompanyName}" Width="*" />
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.8*" />
                                        <DataGridTextColumn Header="Due" Binding="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy}}" Width="0.8*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>

<Window x:Class="DeskFlowAI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeskFlow AI"
        Width="1040"
        Height="650"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#334155" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D8E1EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
    </Window.Resources>

    <Grid Background="#EEF3F8">
        <Grid x:Name="LoginView">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#17324D"
                    Padding="56">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="DeskFlow AI"
                               FontSize="42"
                               FontWeight="SemiBold"
                               Foreground="White" />

                    <TextBlock Text="Musteri, proje, gorev ve belge sureclerini tek masaustu uygulamasinda yonet."
                               Margin="0,18,0,0"
                               FontSize="18"
                               LineHeight="28"
                               TextWrapping="Wrap"
                               Foreground="#D9E6F2" />

                    <Border Margin="0,42,0,0"
                            Padding="18"
                            Background="#24445F"
                            BorderBrush="#3F6380"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Demo kullanici"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="White" />

                            <TextBlock Text="admin@deskflow.ai / Admin123"
                                       Margin="0,8,0,0"
                                       FontSize="14"
                                       Foreground="#CFE0EF" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <Border MaxWidth="420"
                        Margin="56"
                        Padding="34"
                        Background="White"
                        BorderBrush="#D8E1EC"
                        BorderThickness="1"
                        CornerRadius="8"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Sign in"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937" />

                        <TextBlock Text="Sirket calisma alanina giris yap."
                                   Margin="0,8,0,28"
                                   FontSize="15"
                                   Foreground="#64748B" />

                        <TextBlock Text="Email" Style="{StaticResource FieldLabelStyle}" />

                        <TextBox x:Name="EmailTextBox"
                                 Style="{StaticResource InputStyle}"
                                 Text="admin@deskflow.ai" />

                        <TextBlock Text="Password"
                                   Margin="0,18,0,6"
                                   Style="{StaticResource FieldLabelStyle}" />

                        <PasswordBox x:Name="PasswordBox"
                                     Height="42"
                                     Padding="12,0"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="#CBD5E1"
                                     BorderThickness="1"
                                     Password="Admin123"
                                     KeyDown="PasswordBox_KeyDown" />

                        <TextBlock x:Name="LoginErrorTextBlock"
                                   Margin="0,14,0,0"
                                   FontSize="13"
                                   Foreground="#DC2626"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed" />

                        <Button Content="Sign in"
                                Height="42"
                                Margin="0,24,0,0"
                                Background="#2563EB"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Click="SignInButton_Click" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="DashboardView" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="72" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="#D8E1EC"
                    BorderThickness="0,0,0,1"
                    Padding="28,0">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left"
                                VerticalAlignment="Center">
                        <TextBlock Text="DeskFlow AI"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937" />

                            <TextBlock x:Name="SignedInUserTextBlock"
                                   Margin="0,3,0,0"
                                   FontSize="13"
                                   Foreground="#64748B" />
                    </StackPanel>

                    <Button DockPanel.Dock="Right"
                            Content="Sign out"
                            Width="96"
                            Height="36"
                            Margin="0,18,0,18"
                            Click="SignOutButton_Click" />
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Dashboard"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="#1F2937" />

                    <TextBlock Text="Operasyon ozeti ve bekleyen isler."
                               Margin="0,6,0,22"
                               FontSize="15"
                               Foreground="#64748B" />
                </StackPanel>

                <UniformGrid Grid.Row="1"
                             Columns="4"
                             Rows="1"
                             VerticalAlignment="Top">
                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Aktif projeler" Foreground="#64748B" />
                            <TextBlock Text="12" Margin="0,10,0,0" FontSize="34" FontWeight="SemiBold" Foreground="#1F2937" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Acik gorevler" Foreground="#64748B" />
                            <TextBlock Text="38" Margin="0,10,0,0" FontSize="34" FontWeight="SemiBold" Foreground="#1F2937" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Geciken isler" Foreground="#64748B" />
                            <TextBlock Text="5" Margin="0,10,0,0" FontSize="34" FontWeight="SemiBold" Foreground="#B91C1C" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel>
                            <TextBlock Text="AI bekleyen belgeler" Foreground="#64748B" />
                            <TextBlock Text="9" Margin="0,10,0,0" FontSize="34" FontWeight="SemiBold" Foreground="#1F2937" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>
        </Grid>
    </Grid>
</Window>

<Window x:Class="DeskFlowAI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeskFlow AI"
        Width="1160"
        Height="720"
        MinWidth="900"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#334155" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#BFDBFE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#334155" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="#FEF2F2" />
            <Setter Property="BorderBrush" Value="#FECACA" />
            <Setter Property="Foreground" Value="#991B1B" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="OverdueTaskRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                    <Setter Property="Background" Value="#FEF2F2" />
                    <Setter Property="Foreground" Value="#991B1B" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EmployeeWorkloadRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding NeedsCoverage}" Value="True">
                    <Setter Property="Background" Value="#FFFBEB" />
                    <Setter Property="Foreground" Value="#92400E" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="Background" Value="#FAFCFF" />
            <Setter Property="BorderBrush" Value="#D8E1EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1F2937" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="#EEF3F8"
                                BorderBrush="#D8E1EC"
                                BorderThickness="1"
                                CornerRadius="8,8,0,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="White" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#2563EB" />
                                <Setter Property="Foreground" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#EEF3F8">
        <Grid x:Name="LoginView">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#17324D"
                    Padding="56">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="DeskFlow AI"
                               FontSize="42"
                               FontWeight="SemiBold"
                               Foreground="White" />

                    <TextBlock Text="Musteri, proje, gorev ve belge sureclerini tek masaustu uygulamasinda yonet."
                               Margin="0,18,0,0"
                               FontSize="18"
                               LineHeight="28"
                               TextWrapping="Wrap"
                               Foreground="#D9E6F2" />

                    <Border Margin="0,42,0,0"
                            Padding="18"
                            Background="#24445F"
                            BorderBrush="#3F6380"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Demo kullanici"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="White" />

                            <TextBlock Text="admin, manager veya staff @deskflow.ai / Admin123"
                                       Margin="0,8,0,0"
                                       FontSize="14"
                                       Foreground="#CFE0EF" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <Border MaxWidth="420"
                        Margin="56"
                        Padding="34"
                        Background="White"
                        BorderBrush="#D8E1EC"
                        BorderThickness="1"
                        CornerRadius="8"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Sign in"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937" />

                        <TextBlock Text="Sirket calisma alanina giris yap."
                                   Margin="0,8,0,28"
                                   FontSize="15"
                                   Foreground="#64748B" />

                        <TextBlock Text="Email" Style="{StaticResource FieldLabelStyle}" />

                        <TextBox x:Name="EmailTextBox"
                                 Style="{StaticResource InputStyle}"
                                 Text="admin@deskflow.ai" />

                        <TextBlock Text="Password"
                                   Margin="0,18,0,6"
                                   Style="{StaticResource FieldLabelStyle}" />

                        <PasswordBox x:Name="PasswordBox"
                                     Height="42"
                                     Padding="12,0"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="#CBD5E1"
                                     BorderThickness="1"
                                     Password="Admin123"
                                     KeyDown="PasswordBox_KeyDown" />

                        <TextBlock x:Name="LoginErrorTextBlock"
                                   Margin="0,14,0,0"
                                   FontSize="13"
                                   Foreground="#DC2626"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed" />

                        <Button Content="Sign in"
                                Height="42"
                                Margin="0,24,0,0"
                                Background="#2563EB"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Click="SignInButton_Click" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="DashboardView" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="#1E40AF"
                    BorderThickness="0,0,0,1"
                    Padding="22,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0F172A" Offset="0" />
                        <GradientStop Color="#1D4ED8" Offset="0.62" />
                        <GradientStop Color="#0F766E" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="DeskFlow AI"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="White" />

                        <TextBlock x:Name="SignedInUserTextBlock"
                                   Margin="14,3,0,0"
                                   FontSize="13"
                                   Foreground="#DBEAFE" />
                    </StackPanel>

                    <Button DockPanel.Dock="Right"
                            Content="Sign out"
                            Width="90"
                            Height="32"
                            Margin="0,12,0,12"
                            Background="#EFF6FF"
                            BorderBrush="#93C5FD"
                            Foreground="#0F172A"
                            Click="SignOutButton_Click" />
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <UniformGrid Grid.Row="0"
                             Columns="4"
                             Rows="1"
                             Margin="0,0,0,14"
                             VerticalAlignment="Top">
                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,10,0" Background="#EFF6FF">
                        <DockPanel>
                            <TextBlock Text="Aktif projeler" Foreground="#1E3A8A" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock x:Name="ActiveProjectsTextBlock" DockPanel.Dock="Right" Text="0" FontSize="24" FontWeight="SemiBold" Foreground="#1D4ED8" HorizontalAlignment="Right" />
                        </DockPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,10,0" Background="#F0FDF4" BorderBrush="#BBF7D0">
                        <DockPanel>
                            <TextBlock Text="Acik gorevler" Foreground="#166534" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock x:Name="OpenTasksTextBlock" DockPanel.Dock="Right" Text="0" FontSize="24" FontWeight="SemiBold" Foreground="#15803D" HorizontalAlignment="Right" />
                        </DockPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,10,0" Background="#FEF2F2" BorderBrush="#FECACA">
                        <DockPanel>
                            <TextBlock Text="Geciken isler" Foreground="#991B1B" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock x:Name="OverdueTasksTextBlock" DockPanel.Dock="Right" Text="0" FontSize="24" FontWeight="SemiBold" Foreground="#B91C1C" HorizontalAlignment="Right" />
                        </DockPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardStyle}" Background="#FFFBEB" BorderBrush="#FDE68A">
                        <DockPanel>
                            <TextBlock Text="AI bekleyen belgeler" Foreground="#92400E" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock x:Name="PendingAiDocumentsTextBlock" DockPanel.Dock="Right" Text="0" FontSize="24" FontWeight="SemiBold" Foreground="#B45309" HorizontalAlignment="Right" />
                        </DockPanel>
                    </Border>
                </UniformGrid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*" MinWidth="360" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="1*" MinWidth="420" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="18"
                            Background="White"
                            BorderBrush="#D8E1EC"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="2*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Margin="0,0,0,12"
                                    Padding="14"
                                    Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Customers"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Foreground="#0F172A" />

                                        <TextBlock Text="Musteri kayitlari, iletisim bilgileri ve durum takibi."
                                                   Margin="0,4,0,0"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   Foreground="#64748B" />
                                    </StackPanel>

                                    <Button x:Name="DeleteCustomerButton"
                                            Grid.Column="2"
                                            Content="Delete selected"
                                            Width="138"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Click="DeleteCustomerButton_Click" />
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1"
                                  Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="112" />
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="CustomerSearchTextBox"
                                         Height="38"
                                         Padding="12,0"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         BorderBrush="#CBD5E1"
                                         BorderThickness="1"
                                         TextChanged="CustomerSearchTextBox_TextChanged" />

                                <Button Grid.Column="2"
                                        Content="Clear"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="ClearCustomerSearchButton_Click" />
                            </Grid>

                            <DataGrid x:Name="CustomersDataGrid"
                                      Grid.Row="2"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionChanged="CustomersDataGrid_SelectionChanged"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderBrush="#E2E8F0"
                                      BorderThickness="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Company" Binding="{Binding CompanyName}" Width="*" />
                                    <DataGridTextColumn Header="Contact" Binding="{Binding ContactName}" Width="*" />
                                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.3*" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.7*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Grid.Row="3"
                                       Text="Audit log"
                                       Margin="0,14,0,8"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#1F2937" />

                            <DataGrid x:Name="AuditLogsDataGrid"
                                      Grid.Row="4"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderBrush="#E2E8F0"
                                      BorderThickness="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding OccurredAt, StringFormat={}{0:HH:mm:ss}}" Width="0.7*" />
                                    <DataGridTextColumn Header="Actor" Binding="{Binding ActorEmail}" Width="1.2*" />
                                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="0.8*" />
                                    <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1"
                                  Width="10"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeBehavior="PreviousAndNext"
                                  Background="Transparent"
                                  ShowsPreview="True">
                        <GridSplitter.Template>
                            <ControlTemplate TargetType="GridSplitter">
                                <Border Background="#D8E1EC"
                                        Width="2"
                                        CornerRadius="1"
                                        HorizontalAlignment="Center"
                                        Margin="0,8" />
                            </ControlTemplate>
                        </GridSplitter.Template>
                    </GridSplitter>

                    <Border Grid.Column="2"
                            Padding="12"
                            Background="White"
                            BorderBrush="#D8E1EC"
                            BorderThickness="1"
                            CornerRadius="8">
                        <TabControl>
                            <TabItem Header="Customer">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="0,12,0,0">
                                <Border Style="{StaticResource SectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock x:Name="CustomerFormTitleTextBlock"
                                                   Text="Add customer"
                                                   Style="{StaticResource SectionTitleStyle}" />

                                        <TextBlock Text="Company"
                                                   Margin="0,16,0,6"
                                                   Style="{StaticResource FieldLabelStyle}" />

                                        <TextBox x:Name="CustomerCompanyTextBox"
                                                 Style="{StaticResource InputStyle}" />

                                        <TextBlock Text="Contact"
                                                   Margin="0,12,0,6"
                                                   Style="{StaticResource FieldLabelStyle}" />

                                        <TextBox x:Name="CustomerContactTextBox"
                                                 Style="{StaticResource InputStyle}" />

                                        <TextBlock Text="Email"
                                                   Margin="0,12,0,6"
                                                   Style="{StaticResource FieldLabelStyle}" />

                                        <TextBox x:Name="CustomerEmailTextBox"
                                                 Style="{StaticResource InputStyle}" />

                                        <TextBlock x:Name="CustomerFormMessageTextBlock"
                                                   Margin="0,12,0,0"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   Visibility="Collapsed" />

                                        <Button x:Name="AddCustomerButton"
                                                Content="Add customer"
                                                Margin="0,18,0,0"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Click="AddCustomerButton_Click" />

                                        <UniformGrid Columns="2"
                                                     Margin="0,10,0,0">
                                            <Button x:Name="UpdateCustomerButton"
                                                    Content="Update"
                                                    Margin="0,0,5,0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Click="UpdateCustomerButton_Click" />

                                            <Button Content="Clear"
                                                    Margin="5,0,0,0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Click="ClearCustomerFormButton_Click" />
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="Projects">
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.3*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="0.9*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Project list" Style="{StaticResource SectionTitleStyle}" />

                                                <TextBlock Text="Tum projeleri veya secili customer projelerini teslim tarihine gore gosterir."
                                                           Margin="0,4,0,0"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Foreground="#64748B" />

                                                <TextBlock x:Name="SelectedCustomerForProjectTextBlock"
                                                           Text="Once listeden bir customer sec."
                                                           Margin="0,10,0,0"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Foreground="#334155" />
                                            </StackPanel>

                                            <DataGrid x:Name="ProjectsDataGrid"
                                                      Grid.Row="1"
                                                      MinHeight="260"
                                                      Margin="0,16,0,0"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      SelectionMode="Single"
                                                      SelectionChanged="ProjectsDataGrid_SelectionChanged"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      BorderBrush="#E2E8F0"
                                                      BorderThickness="1">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Project" Binding="{Binding Name}" Width="*" />
                                                    <DataGridTextColumn Header="Customer" Binding="{Binding Customer.CompanyName}" Width="*" />
                                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.8*" />
                                                    <DataGridTextColumn Header="Due" Binding="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy}}" Width="0.75*" />
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <TextBlock x:Name="ProjectsEmptyTextBlock"
                                                       Grid.Row="2"
                                                       Text="Bu customer icin henuz proje yok."
                                                       Margin="0,10,0,0"
                                                       FontSize="13"
                                                       Foreground="#64748B"
                                                       Visibility="Collapsed" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <StackPanel>
                                            <TextBlock Text="Project details" Style="{StaticResource SectionTitleStyle}" />

                                            <TextBlock Text="Yeni proje ekle veya listeden sectigin projenin durumunu guncelle."
                                                       Margin="0,4,0,16"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"
                                                       Foreground="#64748B" />

                                            <TextBlock Text="Project name"
                                                       Style="{StaticResource FieldLabelStyle}" />

                                            <TextBox x:Name="ProjectNameTextBox"
                                                     Style="{StaticResource InputStyle}" />

                                            <TextBlock Text="Status"
                                                       Margin="0,12,0,6"
                                                       Style="{StaticResource FieldLabelStyle}" />

                                            <ComboBox x:Name="ProjectStatusComboBox"
                                                      Height="38"
                                                      SelectedIndex="0">
                                                <ComboBoxItem Content="Planning" />
                                                <ComboBoxItem Content="Active" />
                                                <ComboBoxItem Content="On Hold" />
                                                <ComboBoxItem Content="Completed" />
                                            </ComboBox>

                                            <TextBlock Text="Due date"
                                                       Margin="0,12,0,6"
                                                       Style="{StaticResource FieldLabelStyle}" />

                                            <DatePicker x:Name="ProjectDueDatePicker"
                                                        Height="38" />

                                            <Button x:Name="AddProjectButton"
                                                    Content="Add project"
                                                    Margin="0,18,0,0"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Click="AddProjectButton_Click" />

                                            <Button x:Name="UpdateProjectStatusButton"
                                                    Content="Update project status"
                                                    Margin="0,10,0,0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    IsEnabled="False"
                                                    Click="UpdateProjectStatusButton_Click" />

                                            <TextBlock x:Name="ProjectFormMessageTextBlock"
                                                       Margin="0,12,0,0"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"
                                                       Visibility="Collapsed" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Tasks">
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.25*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="0.95*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Task list" Style="{StaticResource SectionTitleStyle}" />

                                                <TextBlock Text="Secili project icindeki gorevler teslim tarihine ve oncelige gore siralanir."
                                                           Margin="0,4,0,0"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Foreground="#64748B" />

                                                <TextBlock x:Name="SelectedProjectForTaskTextBlock"
                                                           Text="Once Projects sekmesinden bir project sec."
                                                           Margin="0,10,0,0"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Foreground="#334155" />

                                                <Grid Margin="0,14,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="10" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="10" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Status filter" Style="{StaticResource FieldLabelStyle}" />
                                                        <ComboBox x:Name="TaskStatusFilterComboBox"
                                                                  Height="36"
                                                                  SelectedIndex="0"
                                                                  SelectionChanged="TaskFilter_Changed">
                                                            <ComboBoxItem Content="All statuses" />
                                                            <ComboBoxItem Content="To Do" />
                                                            <ComboBoxItem Content="In Progress" />
                                                            <ComboBoxItem Content="Blocked" />
                                                            <ComboBoxItem Content="Done" />
                                                        </ComboBox>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Priority filter" Style="{StaticResource FieldLabelStyle}" />
                                                        <ComboBox x:Name="TaskPriorityFilterComboBox"
                                                                  Height="36"
                                                                  SelectedIndex="0"
                                                                  SelectionChanged="TaskFilter_Changed">
                                                            <ComboBoxItem Content="All priorities" />
                                                            <ComboBoxItem Content="Low" />
                                                            <ComboBoxItem Content="Normal" />
                                                            <ComboBoxItem Content="High" />
                                                            <ComboBoxItem Content="Critical" />
                                                        </ComboBox>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="Due filter" Style="{StaticResource FieldLabelStyle}" />
                                                        <ComboBox x:Name="TaskDueDateFilterComboBox"
                                                                  Height="36"
                                                                  SelectedIndex="0"
                                                                  SelectionChanged="TaskFilter_Changed">
                                                            <ComboBoxItem Content="All dates" />
                                                            <ComboBoxItem Content="Overdue" />
                                                            <ComboBoxItem Content="Due today" />
                                                            <ComboBoxItem Content="Due in 7 days" />
                                                            <ComboBoxItem Content="No due date" />
                                                        </ComboBox>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>

                                            <DataGrid x:Name="TasksDataGrid"
                                                      Grid.Row="1"
                                                      MinHeight="260"
                                                      Margin="0,16,0,0"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      SelectionMode="Single"
                                                      SelectionChanged="TasksDataGrid_SelectionChanged"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      BorderBrush="#E2E8F0"
                                                      BorderThickness="1"
                                                      RowStyle="{StaticResource OverdueTaskRowStyle}">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Task" Binding="{Binding Title}" Width="*" />
                                                    <DataGridTextColumn Header="Assigned To" Binding="{Binding AssignedEmployee.FullName}" Width="0.9*" />
                                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.8*" />
                                                    <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="0.75*" />
                                                    <DataGridTextColumn Header="Due" Binding="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy}}" Width="0.75*" />
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <TextBlock x:Name="TasksEmptyTextBlock"
                                                       Grid.Row="2"
                                                       Text="Bu project icin henuz task yok."
                                                       Margin="0,10,0,0"
                                                       FontSize="13"
                                                       Foreground="#64748B"
                                                       Visibility="Collapsed" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <StackPanel>
                                            <TextBlock Text="Task details" Style="{StaticResource SectionTitleStyle}" />

                                            <TextBlock Text="Yeni gorev ekle veya secili gorevin is akis bilgilerini guncelle."
                                                       Margin="0,4,0,16"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"
                                                       Foreground="#64748B" />

                                            <TextBlock Text="Task title"
                                                       Style="{StaticResource FieldLabelStyle}" />

                                            <TextBox x:Name="TaskTitleTextBox"
                                                     Style="{StaticResource InputStyle}" />

                                            <TextBlock Text="Status"
                                                       Margin="0,12,0,6"
                                                       Style="{StaticResource FieldLabelStyle}" />

                                            <ComboBox x:Name="TaskStatusComboBox"
                                                      Height="38"
                                                      SelectedIndex="0">
                                                <ComboBoxItem Content="To Do" />
                                                <ComboBoxItem Content="In Progress" />
                                                <ComboBoxItem Content="Blocked" />
                                                <ComboBoxItem Content="Done" />
                                            </ComboBox>

                                            <TextBlock Text="Priority"
                                                       Margin="0,12,0,6"
                                                       Style="{StaticResource FieldLabelStyle}" />

                                            <ComboBox x:Name="TaskPriorityComboBox"
                                                      Height="38"
                                                      SelectedIndex="1">
                                                <ComboBoxItem Content="Low" />
                                                <ComboBoxItem Content="Normal" />
                                                <ComboBoxItem Content="High" />
                                                <ComboBoxItem Content="Critical" />
                                            </ComboBox>

                                            <TextBlock Text="Assigned to"
                                                       Margin="0,12,0,6"
                                                       Style="{StaticResource FieldLabelStyle}" />

                                            <ComboBox x:Name="TaskAssignedEmployeeComboBox"
                                                      Height="38"
                                                      DisplayMemberPath="FullName"
                                                      SelectedValuePath="Id" />

                                            <TextBlock Text="Due date"
                                                       Margin="0,12,0,6"
                                                       Style="{StaticResource FieldLabelStyle}" />

                                            <DatePicker x:Name="TaskDueDatePicker"
                                                        Height="38" />

                                            <Button x:Name="AddTaskButton"
                                                    Content="Add task"
                                                    Margin="0,18,0,0"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Click="AddTaskButton_Click" />

                                            <Button x:Name="UpdateTaskButton"
                                                    Content="Update task"
                                                    Margin="0,10,0,0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    IsEnabled="False"
                                                    Click="UpdateTaskButton_Click" />

                                            <Button x:Name="MarkTaskDoneButton"
                                                    Content="Mark as done"
                                                    Margin="0,10,0,0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    IsEnabled="False"
                                                    Click="MarkTaskDoneButton_Click" />

                                            <TextBlock x:Name="TaskFormMessageTextBlock"
                                                       Margin="0,12,0,0"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"
                                                       Visibility="Collapsed" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem x:Name="TeamTab" Header="Team">
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.25*" MinWidth="260" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="0.9*" MinWidth="240" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Team overview" Style="{StaticResource SectionTitleStyle}" />

                                                <TextBlock Text="Yoneticiler ekip uygunlugunu, acik is yukunu ve acil durum yedeklerini buradan takip eder."
                                                           Margin="0,4,0,0"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Foreground="#64748B" />
                                            </StackPanel>

                                            <DataGrid x:Name="EmployeesDataGrid"
                                                      Grid.Row="1"
                                                      MinHeight="320"
                                                      Margin="0,16,0,0"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      SelectionMode="Single"
                                                      SelectionChanged="EmployeesDataGrid_SelectionChanged"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      BorderBrush="#E2E8F0"
                                                      BorderThickness="1"
                                                      RowStyle="{StaticResource EmployeeWorkloadRowStyle}">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*" />
                                                    <DataGridTextColumn Header="Dept" Binding="{Binding Department}" Width="0.75*" />
                                                    <DataGridTextColumn Header="Status" Binding="{Binding AvailabilityStatus}" Width="0.85*" />
                                                    <DataGridTextColumn Header="Open" Binding="{Binding OpenTaskCount}" Width="0.45*" />
                                                    <DataGridTextColumn Header="Next due" Binding="{Binding NextOpenTaskDueDate, StringFormat={}{0:dd.MM.yyyy}}" Width="0.7*" />
                                                    <DataGridTextColumn Header="Backup" Binding="{Binding BackupEmployeeName}" Width="0.9*" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>

                                    <GridSplitter Grid.Column="1"
                                                  Width="10"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"
                                                  ResizeBehavior="PreviousAndNext"
                                                  Background="Transparent"
                                                  ShowsPreview="True">
                                        <GridSplitter.Template>
                                            <ControlTemplate TargetType="GridSplitter">
                                                <Border Background="#D8E1EC"
                                                        Width="2"
                                                        CornerRadius="1"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,8" />
                                            </ControlTemplate>
                                        </GridSplitter.Template>
                                    </GridSplitter>

                                    <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <TextBlock Text="Employee details" Style="{StaticResource SectionTitleStyle}" />

                                                <TextBlock Text="Calisan bilgisi, izin araligi ve yerine bakabilecek kisi."
                                                           Margin="0,4,0,16"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Foreground="#64748B" />

                                                <Border Padding="12"
                                                        Margin="0,0,0,16"
                                                        Background="#EFF6FF"
                                                        BorderBrush="#BFDBFE"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <TextBlock x:Name="EmployeeWorkloadSummaryTextBlock"
                                                               Text="Listeden bir calisan sec."
                                                               FontSize="13"
                                                               TextWrapping="Wrap"
                                                               Foreground="#1E3A8A" />
                                                </Border>

                                                <TextBlock Text="Full name" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBox x:Name="EmployeeFullNameTextBox" Style="{StaticResource InputStyle}" />

                                                <TextBlock Text="Email" Margin="0,12,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBox x:Name="EmployeeEmailTextBox" Style="{StaticResource InputStyle}" />

                                                <TextBlock Text="Department" Margin="0,12,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBox x:Name="EmployeeDepartmentTextBox" Style="{StaticResource InputStyle}" />

                                                <TextBlock Text="Role" Margin="0,12,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBox x:Name="EmployeeRoleTextBox" Style="{StaticResource InputStyle}" />

                                                <TextBlock Text="Availability" Margin="0,12,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                <ComboBox x:Name="EmployeeAvailabilityComboBox"
                                                          Height="38"
                                                          SelectedIndex="0">
                                                    <ComboBoxItem Content="Available" />
                                                    <ComboBoxItem Content="Busy" />
                                                    <ComboBoxItem Content="On Leave" />
                                                    <ComboBoxItem Content="Emergency Cover" />
                                                </ComboBox>

                                                <Grid Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="10" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Leave start" Style="{StaticResource FieldLabelStyle}" />
                                                        <DatePicker x:Name="EmployeeLeaveStartDatePicker" Height="38" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Leave end" Style="{StaticResource FieldLabelStyle}" />
                                                        <DatePicker x:Name="EmployeeLeaveEndDatePicker" Height="38" />
                                                    </StackPanel>
                                                </Grid>

                                                <TextBlock Text="Skills / notes" Margin="0,12,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBox x:Name="EmployeeSkillsTextBox"
                                                         Height="70"
                                                         Padding="10,8"
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"
                                                         BorderBrush="#CBD5E1"
                                                         BorderThickness="1" />

                                                <TextBlock Text="Emergency backup" Margin="0,12,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBox x:Name="EmployeeBackupTextBox" Style="{StaticResource InputStyle}" />

                                                <Button x:Name="AddEmployeeButton"
                                                        Content="Add employee"
                                                        Margin="0,18,0,0"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Click="AddEmployeeButton_Click" />

                                                <UniformGrid Columns="2" Margin="0,10,0,0">
                                                    <Button x:Name="UpdateEmployeeButton"
                                                            Content="Update"
                                                            Margin="0,0,5,0"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            IsEnabled="False"
                                                            Click="UpdateEmployeeButton_Click" />

                                                    <Button Content="Clear"
                                                            Margin="5,0,0,0"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Click="ClearEmployeeFormButton_Click" />
                                                </UniformGrid>

                                                <TextBlock x:Name="EmployeeFormMessageTextBlock"
                                                           Margin="0,12,0,0"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Visibility="Collapsed" />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem x:Name="UsersTab" Header="Users">
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" MinWidth="300" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="0.9*" MinWidth="260" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="User accounts" Style="{StaticResource SectionTitleStyle}" />

                                                <TextBlock Text="Admin kullanicilari, rollerini ve calisan baglantilarini buradan yonetir."
                                                           Margin="0,4,0,0"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Foreground="#64748B" />
                                            </StackPanel>

                                            <DataGrid x:Name="UserAccountsDataGrid"
                                                      Grid.Row="1"
                                                      MinHeight="320"
                                                      Margin="0,16,0,0"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      SelectionMode="Single"
                                                      SelectionChanged="UserAccountsDataGrid_SelectionChanged"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      BorderBrush="#E2E8F0"
                                                      BorderThickness="1">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.35*" />
                                                    <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="0.7*" />
                                                    <DataGridTextColumn Header="Employee" Binding="{Binding EmployeeName}" Width="1*" />
                                                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive, Mode=OneWay}" Width="0.55*" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>

                                    <GridSplitter Grid.Column="1"
                                                  Width="10"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"
                                                  ResizeBehavior="PreviousAndNext"
                                                  Background="Transparent"
                                                  ShowsPreview="True">
                                        <GridSplitter.Template>
                                            <ControlTemplate TargetType="GridSplitter">
                                                <Border Background="#D8E1EC"
                                                        Width="2"
                                                        CornerRadius="1"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,8" />
                                            </ControlTemplate>
                                        </GridSplitter.Template>
                                    </GridSplitter>

                                    <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" Margin="0">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <TextBlock Text="User details" Style="{StaticResource SectionTitleStyle}" />

                                                <TextBlock Text="Yeni kullanici olustur, role ata, calisanla bagla veya sifre resetle."
                                                           Margin="0,4,0,16"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Foreground="#64748B" />

                                                <TextBlock Text="Email" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBox x:Name="UserEmailTextBox" Style="{StaticResource InputStyle}" />

                                                <TextBlock Text="Role" Margin="0,12,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                <ComboBox x:Name="UserRoleComboBox"
                                                          Height="38"
                                                          SelectedIndex="2">
                                                    <ComboBoxItem Content="Admin" />
                                                    <ComboBoxItem Content="Manager" />
                                                    <ComboBoxItem Content="Staff" />
                                                </ComboBox>

                                                <TextBlock Text="Employee link" Margin="0,12,0,6" Style="{StaticResource FieldLabelStyle}" />
                                                <ComboBox x:Name="UserEmployeeComboBox"
                                                          Height="38"
                                                          DisplayMemberPath="FullName"
                                                          SelectedValuePath="Id" />

                                                <CheckBox x:Name="UserIsActiveCheckBox"
                                                          Content="Active user"
                                                          Margin="0,14,0,0"
                                                          IsChecked="True"
                                                          FontWeight="SemiBold"
                                                          Foreground="#334155" />

                                                <TextBlock Text="Password / reset"
                                                           Margin="0,14,0,6"
                                                           Style="{StaticResource FieldLabelStyle}" />

                                                <PasswordBox x:Name="NewUserPasswordBox"
                                                             Height="38"
                                                             Padding="12,0"
                                                             VerticalContentAlignment="Center"
                                                             BorderBrush="#CBD5E1"
                                                             BorderThickness="1" />

                                                <Button x:Name="AddUserButton"
                                                        Content="Add user"
                                                        Margin="0,18,0,0"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Click="AddUserButton_Click" />

                                                <Button x:Name="UpdateUserButton"
                                                        Content="Update user"
                                                        Margin="0,10,0,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        IsEnabled="False"
                                                        Click="UpdateUserButton_Click" />

                                                <Button x:Name="ResetUserPasswordButton"
                                                        Content="Reset password"
                                                        Margin="0,10,0,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        IsEnabled="False"
                                                        Click="ResetUserPasswordButton_Click" />

                                                <Button Content="Clear"
                                                        Margin="0,10,0,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Click="ClearUserFormButton_Click" />

                                                <TextBlock x:Name="UserFormMessageTextBlock"
                                                           Margin="0,12,0,0"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Visibility="Collapsed" />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Overview">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="0,12,0,0">
                                        <Border Style="{StaticResource SectionCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Due soon" Style="{StaticResource SectionTitleStyle}" />

                                <TextBlock x:Name="DueSoonNotificationTextBlock"
                                           Text="Son 7 gun icinde teslimi olan proje yok."
                                           Margin="0,8,0,0"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Foreground="#64748B" />

                                <DataGrid x:Name="DueSoonProjectsDataGrid"
                                          Height="110"
                                          Margin="0,10,0,0"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          BorderBrush="#E2E8F0"
                                          BorderThickness="1">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Project" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="Customer" Binding="{Binding Customer.CompanyName}" Width="*" />
                                        <DataGridTextColumn Header="Due" Binding="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy}}" Width="0.8*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SectionCardStyle}" Margin="0">
                                            <StackPanel>
                                                <TextBlock Text="All projects" Style="{StaticResource SectionTitleStyle}" />

                                <DataGrid x:Name="AllProjectsDataGrid"
                                          Height="150"
                                          Margin="0,10,0,0"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          BorderBrush="#E2E8F0"
                                          BorderThickness="1">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Project" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="Customer" Binding="{Binding Customer.CompanyName}" Width="*" />
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.8*" />
                                        <DataGridTextColumn Header="Due" Binding="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy}}" Width="0.8*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
